{
    "redirects": [
        { "source": "/bescheid-check(?:/)?", "destination": "/?action=legal_help", "permanent": true },
        { "source": "/ratgeber/wohngeld-trotz-buergergeld(?:/)?", "destination": "/ratgeber/buergergeld-oder-wohngeld/", "permanent": true },
        { "source": "/ratgeber/erstausstattung-fuer-die-wohnung(?:/)?", "destination": "/", "permanent": true },
        { "source": "/ratgeber/kontoauszuege-jobcenter-schwaerzen(?:/)?", "destination": "/", "permanent": true },
        { "source": "/wohngeld/student(?:/)?", "destination": "/", "permanent": true },
        { "source": "/ratgeber/buergergeld-fuer-studenten-und-azubis(?:/)?", "destination": "/", "permanent": true },
        { "source": "/ratgeber/buergergeld-fuer-selbststaendige(?:/)?", "destination": "/", "permanent": true },
        { "source": "/wohngeld", "destination": "/", "permanent": true },
        { "source": "/buergergeld", "destination": "/", "permanent": true },
        { "source": "/buergergeld-grundsicherung", "destination": "/", "permanent": true },
        { "source": "/staedte", "destination": "/", "permanent": true },
        { "source": "/wohngeld/:path*", "destination": "/", "permanent": true },
        { "source": "/wohngeldrechner/:path*", "destination": "/", "permanent": true },
        { "source": "/buergergeld/:path*", "destination": "/", "permanent": true },
        { "source": "/buergergeld-grundsicherung/:path*", "destination": "/", "permanent": true },
        { "source": "/:citySlug(?!avgs|bildung-und-teilhabe|ueber-uns|impressum|datenschutz|agb|danke|erfolg|abbruch|pdf-paket|admin|api|lexikon|ratgeber|_astro|favicon\\.png|apple-touch-icon\\.png|logo\\.png|og-image\\.jpg|grid-pattern\\.svg|robots\\.txt|sitemap.*|scripts|images|downloads|forms)[^/]+/:path*", "destination": "/", "permanent": true }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                },
                {
                    "key": "Strict-Transport-Security",
                    "value": "max-age=63072000; includeSubDomains; preload"
                },
                {
                    "key": "Content-Security-Policy",
                    "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://vercel.live; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' http://localhost:5000 https://sozialer-navigator-api.onrender.com; object-src 'none'; base-uri 'self';"
                }
            ]
        }
    ],
    "crons": [
        {
            "path": "/api/cron/send-wba-reminders",
            "schedule": "0 8 * * *"
        }
    ]
}
---
// src/layouts/Layout.astro
import Nav from '../components/nav.astro';
import Footer from '../components/footer.astro';
import FeedbackWidget from '../components/feedback-widget.astro';
import ChatWidget from '../components/chat-widget.jsx';
import Schema from '../components/seo/schema.astro';
import PrivacyBanner from '../components/ui/privacy-banner.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  hideNav?: boolean;
  class?: string;
  canonical?: string;
  type?: "website" | "article" | "city-service";
  city?: string; // For Local SEO
  serviceType?: "Wohngeld" | "Bürgergeld" | "WBS";
  faq?: { question: string; answer: string }[];
}

const { 
  title, 
  description = "Sozialer Navigator - Ihre rechtssichere Hilfe für 2026", 
  hideNav = false, 
  canonical,
  type = "website",
  city,
  serviceType,
  faq
} = Astro.props;
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical || new URL(Astro.url.pathname.endsWith('/') ? Astro.url.pathname : Astro.url.pathname + '/', Astro.site)} />
    <title>{title}</title>

    <!-- OpenGraph / Social Media -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL('/images/hero-navigator.png', Astro.site)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={new URL(Astro.url.pathname, Astro.site)} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL('/images/hero-navigator.png', Astro.site)} />
    
    <!-- Lucide Icons -->
    <!-- Lucide Icons removed: using react-lucide or inline SVGs for privacy -->
    
    <Schema 
      type={type}
      title={title}
      description={description}
      canonicalUrl={canonical || new URL(Astro.url.pathname.endsWith('/') ? Astro.url.pathname : Astro.url.pathname + '/', Astro.site).href}
      city={city}
      serviceType={serviceType}
      faq={faq}
    />

    <style is:global>
        /* Styling für Rechtstexte */
        .prose h1 { font-weight: 900; font-size: 2.5rem; margin-bottom: 2rem; color: #0f172a; letter-spacing: -0.05em; font-style: italic; }
        .prose h2 { font-weight: 800; font-size: 1.5rem; margin-top: 3rem; margin-bottom: 1rem; color: #0f172a; }
        .prose h3 { font-weight: 700; font-size: 1.25rem; margin-top: 2rem; margin-bottom: 0.75rem; color: #0f172a; }
        .prose p { margin-bottom: 1rem; line-height: 1.7; color: #475569; }
        .prose a { color: #2563eb; font-weight: 600; text-decoration: underline; text-decoration-color: #bfdbfe; text-underline-offset: 4px; }
        .prose a:hover { color: #0f172a; text-decoration-color: #2563eb; }
    </style>
    <slot name="head" />
  </head>
  <body class={`antialiased font-sans flex flex-col min-h-screen ${Astro.props.class || 'bg-[var(--bg-base)] text-[var(--text-primary)]'}`}>
    {!hideNav && <Nav />}
    <div class="flex-grow">
      <slot />
    </div>
    <Footer />
    <FeedbackWidget />
    <ChatWidget client:load />
    <PrivacyBanner />
  </body>
</html>

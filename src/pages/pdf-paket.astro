---
import Layout from '../layouts/layout.astro';
import { TrustPdfGenerator } from '../components/trust-pdf-generator.jsx';
---

<Layout title="Sozialer Navigator - Offizieller Antrag" hideNav={false}>
    <div class="bg-surface-muted min-h-screen py-20">
        <div class="max-w-4xl mx-auto px-6">
            
            <div class="mb-12">
                <a href="/" class="text-xs font-bold uppercase tracking-widest text-slate-500 hover:text-brand-blue mb-4 inline-block transition-colors">&larr; Zurück zum Rechner</a>
                <h1 class="text-4xl font-sans font-bold text-slate-900 mb-4">Ihr offizieller Antrag</h1>
                <p class="text-slate-600 text-lg max-w-2xl font-medium">
                    Fast geschafft! Geben Sie Ihre Adresse ein, um das offizielle Formular direkt in Ihrem Browser vorausfüllen zu lassen.
                </p>
            </div>

            <!-- Client-Side PDF Generator Component -->
            <TrustPdfGenerator client:load />
            
        </div>
    </div>
</Layout>

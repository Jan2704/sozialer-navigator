---
import Layout from '../../layouts/layout.astro';
import { getCollection } from 'astro:content';
export const prerender = true;
import { slugify } from '../../utils/slugify';
import { ArrowRight, BookOpen, Share2 } from 'lucide-react';

export async function getStaticPaths() {
  const blogEntries = await getCollection('lexikon');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

import SchemaOrg from '../../components/seo/seo-schema.astro';
---

<Layout title={`${entry.data.title} | Lexikon`} activePage="lexikon">
  
    <fragment slot="head">
        <meta property="og:type" content="article" />
        <meta property="og:title" content={entry.data.title} />
        <meta property="og:description" content={entry.data.description} />
        <meta property="og:url" content={`https://sozialer-navigator.de/lexikon/${entry.slug}`} />

        <SchemaOrg 
            type="TechnicalArticle" 
            data={{
                title: entry.data.title,
                description: entry.data.description,
                url: `https://sozialer-navigator.de/lexikon/${entry.slug}`,
                datePublished: "2025-10-01", // Fallback launch date
                dateModified: entry.data.lastUpdated ? entry.data.lastUpdated.toISOString().split('T')[0] : new Date().toISOString().split('T')[0]
            }} 
        />
        <SchemaOrg 
            type="BreadcrumbList" 
            data={{
                items: [
                    { name: "Startseite", url: "/" },
                    { name: "Lexikon", url: "/lexikon" },
                    { name: entry.data.title, url: `/lexikon/${entry.slug}` }
                ]
            }}
        />
        {entry.data.faqs && (
            <SchemaOrg 
                type="FAQPage" 
                data={{
                    items: entry.data.faqs.map(faq => ({ q: faq.question, a: faq.answer }))
                }}
            />
        )}
    </fragment>

    <main class="min-h-screen bg-surface-muted font-sans pb-32">
        
        <!-- Header Section (Dark Navy) -->
        <div class="relative bg-brand-navy pt-32 pb-24 overflow-hidden">
             <!-- Background Elements -->
             <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20 mix-blend-soft-light pointer-events-none"></div>
             <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-brand-gold rounded-full blur-[120px] opacity-10 pointer-events-none transform translate-x-1/3 -translate-y-1/3"></div>

             <div class="max-w-4xl mx-auto px-6 relative z-10 text-center">
                 
                 <nav class="inline-flex items-center gap-2 text-sm font-medium text-slate-400 mb-8 bg-white/5 px-4 py-2 rounded-full border border-white/10 backdrop-blur-sm">
                    <a href="/lexikon" class="hover:text-brand-gold transition-colors">Lexikon</a>
                    <span class="text-slate-600">/</span>
                    <span class="text-brand-gold truncate max-w-[200px]">{entry.data.title}</span>
                </nav>

                <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-medium text-white mb-8 leading-tight">
                    {entry.data.title}
                </h1>

                <div class="text-xl md:text-2xl text-slate-300 font-light leading-relaxed max-w-2xl mx-auto">
                    {entry.data.description}
                </div>
             </div>
        </div>

        <div class="max-w-6xl mx-auto px-6 -mt-12 relative z-20">
            <div class="grid lg:grid-cols-[1fr_320px] gap-12 items-start">
                
                <!-- Main Content Column -->
                <article class="bg-white rounded-sm shadow-premium p-8 md:p-12 border border-slate-100">
                    
                    <!-- Content Body -->
                    <div class="prose prose-lg prose-slate max-w-none 
                        prose-headings:font-serif prose-headings:font-medium prose-headings:text-brand-navy
                        prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-6 
                        prose-p:text-slate-600 prose-p:leading-relaxed prose-p:font-light
                        prose-strong:text-brand-navy prose-strong:font-semibold
                        prose-a:text-brand-gold prose-a:no-underline hover:prose-a:text-brand-gold-light hover:prose-a:underline prose-a:transition-colors
                        prose-li:text-slate-600 prose-li:marker:text-brand-gold
                        prose-blockquote:border-l-brand-gold prose-blockquote:bg-surface-muted prose-blockquote:py-4 prose-blockquote:px-8 prose-blockquote:not-italic prose-blockquote:text-brand-navy">
                        <Content />
                    </div>

                    <!-- Article Footer/Actions -->
                    <div class="mt-16 pt-8 border-t border-slate-100 flex items-center justify-between">
                        <p class="text-slate-400 text-sm italic font-serif">
                            Stand: {new Date().toLocaleDateString('de-DE', { year: 'numeric', month: 'long' })}
                        </p>
                        <button class="inline-flex items-center gap-2 text-slate-500 hover:text-brand-navy transition-colors text-sm font-medium tracking-wide uppercase">
                            <Share2 className="w-4 h-4" />
                            Teilen
                        </button>
                    </div>

                </article>

                <!-- Sidebar Column -->
                <aside class="space-y-8 sticky top-32">
                    
                    <!-- Topic Context Widget -->
                    {(() => {
                        const t = entry.data.title.toLowerCase();
                        const s = entry.slug.toLowerCase();
                        
                        const isWohngeld = t.includes('wohngeld') || t.includes('miet') || s.includes('wohngeld');
                        const isSgbXii = t.includes('sgb xii') || t.includes('grundsicherung im alter') || t.includes('renten') || s.includes('sgb-xii');

                        let targetLink = "/buergergeld/";
                        let targetName = "Bürgergeld";

                        if (isWohngeld) {
                            targetLink = "/wohngeld/";
                            targetName = "Wohngeld";
                        } else if (isSgbXii) {
                            targetLink = "/buergergeld-grundsicherung/";
                            targetName = "Grundsicherung";
                        }

                        return (
                            <div class="bg-white border border-slate-200 p-8 rounded-sm shadow-sm">
                                <h4 class="text-xs font-bold uppercase tracking-[0.2em] text-slate-400 mb-6 flex items-center gap-3">
                                    <div class="h-[1px] w-8 bg-brand-gold"></div>
                                    Kontext
                                </h4>
                                <p class="text-sm text-slate-600 mb-6 leading-relaxed">
                                    Der Begriff <strong class="text-brand-navy">{entry.data.title}</strong> gehört zum Themenbereich {targetName}.
                                </p>
                                <a href={targetLink} class="group flex items-center justify-between w-full p-4 bg-surface-muted hover:bg-brand-navy hover:text-white transition-all duration-300 border border-slate-100">
                                    <span class="text-sm font-serif font-medium">Zum {targetName}-Ratgeber</span>
                                    <ArrowRight className="w-4 h-4 text-brand-gold" />
                                </a>
                            </div>
                        );
                    })()}

                    <!-- Expert Help Widget -->
                    <div class="bg-brand-navy p-8 rounded-sm shadow-xl relative overflow-hidden text-center">
                        <div class="absolute top-0 right-0 w-32 h-32 bg-brand-gold rounded-full blur-[40px] opacity-10 pointer-events-none"></div>
                        
                        <div class="relative z-10">
                             <div class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center text-brand-gold mx-auto mb-6 border border-white/5">
                                <BookOpen className="w-5 h-5" />
                            </div>
                            <h4 class="text-xl font-serif text-white mb-2">Unklarheiten?</h4>
                            <p class="text-white/60 text-sm leading-relaxed mb-8 font-light">
                                Unsere Experten prüfen Ihren Fall individuell und rechtssicher.
                            </p>
                            <a href="mailto:hilfe@sozialer-navigator.de" class="inline-block w-full bg-brand-gold text-brand-navy hover:bg-white transition-colors py-3 px-6 text-sm font-bold uppercase tracking-widest">
                                Kostenlos anfragen
                            </a>
                        </div>
                    </div>

                </aside>
            </div>
        </div>
    </main>

</Layout>

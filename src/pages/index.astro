---
// index.astro - Sozialer Navigator 2026 - Law Firm Aesthetic
import { wohngeldData } from '../data/wohngeld-data.js';
import { defaultFaqs } from '../data/faqs.js';
import { SmartCalculator } from '../components/smart-calculator.jsx';
import ResultsSection from '../components/results-section.astro';
import SchemaOrg from '../components/seo/seo-schema.astro';
import SuccessRoadmap from '../components/success-roadmap.astro';
import Layout from '../layouts/layout.astro';
import Faq from '../components/faq.astro';
import TrustBadges from '../components/trust-badges.astro';
import BestandskundenSection from '../components/bestandskunden-section.astro';
import WbaReminderModal from '../components/wba-reminder-modal.astro';

import '../styles/global.css';

export const prerender = true;

const description = "Rechtlich fundierte Anspruchsprüfung für Wohngeld & Bürgergeld 2026. Anonym. Kostenlos. Ohne Registrierung.";
---

<Layout 
    title="Sozialleistungen prüfen | Rechtssicher & Kostenlos"
    description={description}
    hideNav={false}
    class="bg-surface-base"
    faq={defaultFaqs}
>

    <!-- SEO Meta & Schema -->
    <fragment slot="head">
        <meta property="og:type" content="website" />
        <meta property="og:title" content="Sozialer Navigator | Rechtliche Anspruchsprüfung 2026" />
        <meta property="og:description" content={description} />
        <meta property="og:image" content="/apple-touch-icon.png" />
        <meta property="og:url" content="https://sozialer-navigator.de/" />

        <SchemaOrg type="Organization" />
        <SchemaOrg type="Website" />
        <SchemaOrg type="SoftwareApplication" />
        
        <script is:inline src="/scripts/lucide.min.js"></script>
        
        <script>
            import { gsap } from 'gsap';
            import { ScrollTrigger } from 'gsap/ScrollTrigger';
            import Chart from 'chart.js/auto';

            gsap.registerPlugin(ScrollTrigger);

            window.Chart = Chart;
            window.gsap = gsap;
            window.ScrollTrigger = ScrollTrigger;

            if (window.lucide) {
                window.lucide.createIcons();
            }
            
            document.addEventListener('astro:page-load', () => {
                if (window.lucide) window.lucide.createIcons();
            });
        </script>
        
        <style>
            /* View Transitions */
            .view-section { display: none; opacity: 0; transition: opacity 0.4s ease-in-out; }
            .view-section.active { display: block; opacity: 1; }
        </style>
    </fragment>

    <main class="min-h-screen relative pt-0 pb-32">

        <!-- VIEW 1: HOME -->
        <section id="view-home" class="view-section active w-full relative z-10">
             
             <!-- HERO SECTION (Law Firm Style) -->
            <div class="relative w-full min-h-[90vh] flex items-center overflow-hidden bg-brand-navy">
                
                <!-- Sophisticated Background -->
                <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20 mix-blend-soft-light pointer-events-none"></div>
                <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-blue-900/10 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>
                <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-indigo-900/5 rounded-full blur-[100px] translate-y-1/2 -translate-x-1/4 pointer-events-none"></div>
                
                <!-- Content Container -->
                <div class="relative z-10 w-full max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-16 items-center"> 
                    
                    <!-- Text Content -->
                    <div class="text-left animate-slide-up">
                        
                         <div class="inline-flex items-center gap-3 mb-8">
                            <div class="h-[1px] w-12 bg-brand-gold"></div>
                            <span class="text-brand-gold text-xs font-bold uppercase tracking-[0.2em] font-sans">Offizielle Berechnung 2026</span>
                         </div>

                        <h1 class="font-serif font-medium tracking-tight mb-8 text-white text-5xl md:text-7xl leading-[1.1]">
                            Ihr Anspruch auf <br />

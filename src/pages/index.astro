    <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    // View Switching Logic is now handled centrally in ResultsSection.astro to ensure consistency
    
    // Cookie Logic
    window.acceptCookies = () => {
        localStorage.setItem('cookieConsent', 'granted');
        const banner = document.getElementById('cookie-banner');
        if(banner) banner.classList.add('hidden');
    };

    window.declineCookies = () => {
        localStorage.setItem('cookieConsent', 'denied');
        const banner = document.getElementById('cookie-banner');
        if(banner) banner.classList.add('hidden');
    };

    document.addEventListener('DOMContentLoaded', () => {
        const consent = localStorage.getItem('cookieConsent');
        if (consent === null) {
            const banner = document.getElementById('cookie-banner');
            if(banner) {
                banner.classList.remove('hidden');
                requestAnimationFrame(() => banner.classList.remove('translate-y-full'));
            }
        }

        // Open lead modal if requested via URL query params
        const params = new URLSearchParams(window.location.search);
        if (params.get('action') === 'bescheid-check' || params.get('action') === 'legal_help') {
            setTimeout(() => {
                if (typeof window.openLeadModal === 'function') {
                    window.openLeadModal('legal_help');
                }
            }, 300);
        }
    });

    // Scroll Triggered Stagger Animations
    document.addEventListener('astro:page-load', () => {
        // Hero Content entrance
        gsap.from('#view-home .hero-title', { opacity: 0, y: 24, duration: 0.8, ease: 'power3.out' });
        gsap.from('#view-home .hero-description', { opacity: 0, y: 16, duration: 0.8, delay: 0.2, ease: 'power3.out' });
        gsap.from('#view-home .hero-features', { opacity: 0, y: 16, duration: 0.8, delay: 0.4, ease: 'power3.out' });
        gsap.from('#view-home .hero-buttons', { opacity: 0, y: 16, duration: 0.8, delay: 0.6, ease: 'power3.out' });

        // Advantages Grid
        gsap.from('.advantage-card', {
            scrollTrigger: {
                trigger: '.advantages-grid',
                start: 'top 85%',
                toggleActions: 'play none none none'
            },
            opacity: 0,
            y: 32,
            stagger: 0.15,
            duration: 0.8,
            ease: 'power3.out'
        });

        // Process Grid
        gsap.from('.process-card', {
            scrollTrigger: {
                trigger: '.process-grid',
                start: 'top 85%',
                toggleActions: 'play none none none'
            },
            opacity: 0,
            y: 32,
            stagger: 0.15,
            duration: 0.8,
            ease: 'power3.out'
        });

        // Mission visual card
        gsap.from('.mission-visual', {
            scrollTrigger: {
                trigger: '.mission-visual',
                start: 'top 85%',
                toggleActions: 'play none none none'
            },
            opacity: 0,
            scale: 0.97,
            duration: 0.8,
            ease: 'power3.out'
        });
    });
    </script>
    <script is:inline src="/scripts/lucide.min.js"></script>
    <script is:inline>
        // Lucide icons init — runs after DOM is fully parsed (script is at body-end)
        if (window.lucide) window.lucide.createIcons();
        document.addEventListener('astro:page-load', () => {
            if (window.lucide) window.lucide.createIcons();
        });
    </script>

        <div class="text-sm text-slate-300 font-light max-w-2xl leading-relaxed">
            <h4 class="text-white font-serif mb-2">Datenschutz-Präferenz</h4>
            <p>Wir respektieren Ihre Privatsphäre. Wir nutzen Cookies ausschließlich für die technische Funktionalität. Es werden keine persönlichen Daten ohne Ihre explizite Handlung gespeichert.</p>
        </div>
        <div class="flex gap-4 shrink-0">
            <button onclick="acceptCookies()" class="bg-brand-gold text-brand-navy px-8 py-3 text-xs font-bold uppercase tracking-widest hover:bg-white transition-colors">
                Zustimmen
            </button>
            <button onclick="declineCookies()" class="text-slate-400 hover:text-white text-xs font-bold uppercase tracking-widest transition-colors px-4 py-3">
                Ablehnen
            </button>
        </div>
    </div>

    <script is:inline define:vars={{ cityData: wohngeldData }}>
        window.cityData = cityData;
    </script>
    
    <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    // View Switching Logic (Consolidated)
    // View Switching Logic is now handled centrally in ResultsSection.astro to ensure consistency
    // This prevents race conditions and scroll-jumping bugs.
    
    // Cookie Logic
    window.acceptCookies = () => {
        localStorage.setItem('cookieConsent', 'granted');
        const banner = document.getElementById('cookie-banner');
        if(banner) banner.classList.add('hidden');
    };

    window.declineCookies = () => {
        localStorage.setItem('cookieConsent', 'denied');
        const banner = document.getElementById('cookie-banner');
        if(banner) banner.classList.add('hidden');
    };

    document.addEventListener('DOMContentLoaded', () => {
        const consent = localStorage.getItem('cookieConsent');
        if (consent === null) {
            const banner = document.getElementById('cookie-banner');
            if(banner) {
                banner.classList.remove('hidden');
                requestAnimationFrame(() => banner.classList.remove('translate-y-full'));
            }
        }
    });
    </script>
    <WbaReminderModal />
</Layout>
---
// index.astro - Amtly 2026 - Fintech Aesthetic
import { wohngeldData } from '../data/wohngeld-data.js';
import { defaultFaqs } from '../data/faqs.js';
import { SmartCalculator } from '../components/smart-calculator.jsx';
import ResultsSection from '../components/results-section.astro';
import SchemaOrg from '../components/seo/seo-schema.astro';
import SuccessRoadmap from '../components/success-roadmap.astro';
import Layout from '../layouts/layout.astro';
import Faq from '../components/faq.astro';
import TrustBadges from '../components/trust-badges.astro';
import WbaReminderModal from '../components/wba-reminder-modal.astro';

import '../styles/global.css';

export const prerender = true;

const description = "Verschenke kein Geld! Finde mit dem Amtly Universal-Fördercheck in nur 2 Minuten anonym heraus, welche staatlichen Zuschüsse dir zustehen, und fülle deine Anträge sofort digital aus.";
---

<Layout 
    title="Amtly — Der universelle Förder-Check für staatliche Zuschüsse"
    description={description}
    hideNav={false}
    class="bg-surface-base"
    faq={defaultFaqs}
>

    <!-- SEO Meta & Schema -->
    <fragment slot="head">
        <meta property="og:type" content="website" />
        <meta property="og:title" content="Wohngeld & Bürgergeld Rechner 2026 | Kostenlos Anspruch prüfen" />
        <meta property="og:description" content={description} />
        <meta property="og:image" content="/apple-touch-icon.png" />
        <meta property="og:url" content="https://sozialer-navigator.de/" />

        <SchemaOrg type="Organization" />
        <SchemaOrg type="Website" />
        <SchemaOrg type="SoftwareApplication" />
        
        <script>
            import { gsap } from 'gsap';
            import { ScrollTrigger } from 'gsap/ScrollTrigger';
            import Chart from 'chart.js/auto';

            gsap.registerPlugin(ScrollTrigger);

            window.Chart = Chart;
            window.gsap = gsap;
            window.ScrollTrigger = ScrollTrigger;
        </script>
        
        <!-- Lucide: deferred to end of body via slot:body-end to avoid render-blocking -->
        
        <style>
            /* View Transitions */
            .view-section { display: none; opacity: 0; transition: opacity 0.4s ease-in-out; }
            .view-section.active { display: block; opacity: 1; }

            /* Dashboard Grid Flow Animations */
            @keyframes dash {
                to { stroke-dashoffset: -40; }
            }
            @keyframes dash-reverse {
                to { stroke-dashoffset: 40; }
            }
            .animate-dash {
                animation: dash 1.5s linear infinite;
            }
            .animate-dash-reverse {
                animation: dash-reverse 1.5s linear infinite;
            }

            /* Custom float for bottom card with centering */
            @keyframes floatMedium {
                0%, 100% { transform: translate(-50%, 0px) scale(1); }
                50% { transform: translate(-50%, -8px) scale(1.01); }
            }
            .animate-float-medium {
                animation: floatMedium 5s ease-in-out infinite;
            }
        </style>
    </fragment>

    <main class="min-h-screen relative pt-0 pb-32">

        <!-- VIEW 1: HOME -->
        <section id="view-home" class="view-section active w-full relative z-10 bg-white">
             
        <!-- HERO SECTION (Plerouse Style - Light Mode) -->
        <div class="relative w-full min-h-[90vh] flex items-center overflow-hidden bg-white border-b border-slate-100">
            <!-- Subtle light dot grid pattern -->
            <div class="absolute inset-0 opacity-40 pointer-events-none" style="background-image: radial-gradient(rgba(15, 23, 42, 0.07) 1.5px, transparent 1.5px); background-size: 24px 24px;"></div>
            
            <!-- Glowing background elements -->
            <div class="absolute top-0 right-1/4 w-[500px] h-[500px] bg-[#0EA5E9]/8 rounded-full blur-[140px] pointer-events-none"></div>
            <div class="absolute bottom-12 left-1/4 w-[400px] h-[400px] bg-[#0D9488]/8 rounded-full blur-[120px] pointer-events-none"></div>
            
            <!-- Content Container -->
            <div class="relative z-10 w-full max-w-7xl mx-auto px-6 grid lg:grid-cols-12 gap-12 md:gap-16 items-center pt-28 pb-20"> 
                
                <!-- Text Content Left -->
                <div class="lg:col-span-6 relative z-10">
                    <div class="text-left animate-slide-up">

                        <!-- Badge + Social Proof Row -->
                        <div class="flex flex-wrap items-center gap-3 mb-5">
                            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#0EA5E9]/5 border border-[#0EA5E9]/15 backdrop-blur-sm">
                                <span class="flex h-2 w-2 rounded-full bg-[#0EA5E9] animate-pulse"></span>
                                <span class="text-[#0EA5E9] text-xs font-black tracking-widest uppercase">Förder-Check 2026</span>
                            </div>
                            <div class="flex items-center gap-1.5 text-xs text-slate-500">
                                <i data-lucide="users" class="w-3.5 h-3.5 text-[#0D9488] flex-shrink-0"></i>
                                <span><span id="social-counter" class="font-black text-slate-800">18.423</span> Haushalte haben bereits geprüft</span>
                            </div>
                        </div>

                        <!-- Loss-Framing Headline -->
                        <h1 class="hero-title font-sans font-black tracking-tight mb-5 text-slate-900 text-5xl md:text-6xl lg:text-[4.5rem] leading-[1.05]">
                            Verschenkst du jeden Monat <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#0EA5E9] to-[#0D9488]">Geld vom Staat?</span>
                        </h1>

                        <!-- Subline -->
                        <p class="hero-description text-base md:text-lg text-slate-600 leading-relaxed mb-6 max-w-lg font-light">
                            Die meisten Haushalte wissen nicht, was ihnen zusteht. Prüfe in 2&nbsp;Minuten kostenlos deinen Anspruch auf Wohngeld, Bürgergeld, Kinderzuschlag&nbsp;& mehr.
                        </p>

                        <!-- Stat Pills -->
                        <div class="hero-stats flex flex-wrap gap-2.5 mb-8">
                            <div class="flex items-center gap-1.5 px-3.5 py-2 rounded-full bg-slate-50 border border-slate-200 text-xs">
                                <span class="text-slate-400">Ø</span>
                                <span class="font-black text-slate-900">487&nbsp;€/Monat</span>
                                <span class="text-slate-400">Förderung</span>
                            </div>
                            <div class="flex items-center gap-1.5 px-3.5 py-2 rounded-full bg-slate-50 border border-slate-200 text-xs">
                                <i data-lucide="clock" class="w-3 h-3 text-slate-400"></i>
                                <span class="font-black text-slate-900">2&nbsp;Minuten</span>
                                <span class="text-slate-400">Check</span>
                            </div>
                            <div class="flex items-center gap-1.5 px-3.5 py-2 rounded-full bg-[#0D9488]/5 border border-[#0D9488]/15 text-xs">
                                <span class="font-black text-[#0D9488]">100%</span>
                                <span class="text-[#0D9488]/70">Kostenlos</span>
                            </div>
                        </div>

                        <!-- Micro-Commitment Selector -->
                        <div class="hero-buttons">
                            <p class="text-xs font-semibold text-slate-500 mb-3 uppercase tracking-wider">Wie viele Personen leben in deinem Haushalt?</p>
                            <div class="grid grid-cols-4 gap-2 mb-4 max-w-sm">
                                <button data-persons="1" class="person-selector-btn group flex flex-col items-center gap-1 py-3.5 rounded-xl border-2 border-slate-200 bg-white hover:border-[#0EA5E9] hover:bg-[#0EA5E9]/5 transition-all duration-200 font-black text-slate-700 text-lg hover:text-[#0EA5E9] hover:scale-[1.05] shadow-sm" aria-label="1 Person">
                                    1
                                    <span class="text-[9px] font-medium text-slate-400 group-hover:text-[#0EA5E9]/60 normal-case tracking-normal">Person</span>
                                </button>
                                <button data-persons="2" class="person-selector-btn group flex flex-col items-center gap-1 py-3.5 rounded-xl border-2 border-slate-200 bg-white hover:border-[#0EA5E9] hover:bg-[#0EA5E9]/5 transition-all duration-200 font-black text-slate-700 text-lg hover:text-[#0EA5E9] hover:scale-[1.05] shadow-sm" aria-label="2 Personen">
                                    2
                                    <span class="text-[9px] font-medium text-slate-400 group-hover:text-[#0EA5E9]/60 normal-case tracking-normal">Personen</span>
                                </button>
                                <button data-persons="3" class="person-selector-btn group flex flex-col items-center gap-1 py-3.5 rounded-xl border-2 border-slate-200 bg-white hover:border-[#0EA5E9] hover:bg-[#0EA5E9]/5 transition-all duration-200 font-black text-slate-700 text-lg hover:text-[#0EA5E9] hover:scale-[1.05] shadow-sm" aria-label="3-4 Personen">
                                    3–4
                                    <span class="text-[9px] font-medium text-slate-400 group-hover:text-[#0EA5E9]/60 normal-case tracking-normal">Personen</span>
                                </button>
                                <button data-persons="4" class="person-selector-btn group flex flex-col items-center gap-1 py-3.5 rounded-xl border-2 border-[#0D9488] bg-[#0D9488]/5 transition-all duration-200 font-black text-[#0D9488] text-lg hover:scale-[1.05] shadow-sm relative" aria-label="5 oder mehr Personen">
                                    5+
                                    <span class="text-[9px] font-medium text-[#0D9488]/60 normal-case tracking-normal">Personen</span>
                                    <span class="absolute -top-2 -right-2 text-[7px] font-black bg-[#0D9488] text-white px-1.5 py-0.5 rounded-full uppercase tracking-wide">Top</span>
                                </button>
                            </div>

                            <!-- Trust micro-copy -->
                            <p class="text-[11px] text-slate-400 flex items-center gap-1.5">
                                <i data-lucide="lock" class="w-3 h-3 flex-shrink-0"></i>
                                Keine Anmeldung &nbsp;·&nbsp; DSGVO-konform &nbsp;·&nbsp; Daten verlassen nie deinen Browser
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Right Side: Interactive Calculation Matrix (Plerouse Dashboard Style) -->
                <div class="lg:col-span-6 relative flex justify-center items-center w-full min-h-[480px]">
                    <!-- Background glows behind dashboard -->
                    <div class="absolute w-[400px] h-[400px] bg-gradient-to-tr from-[#0EA5E9]/10 to-[#0D9488]/10 rounded-full blur-3xl pointer-events-none"></div>

                    <!-- Glowing SVG Flow Lines (Data Streams) -->
                    <svg class="absolute inset-0 w-full h-full pointer-events-none z-0" viewBox="0 0 480 480" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <defs>
                            <linearGradient id="pink-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" stop-color="#0EA5E9" />
                                <stop offset="100%" stop-color="#0D9488" />
                            </linearGradient>
                            <linearGradient id="lime-grad" x1="100%" y1="0%" x2="0%" y2="100%">
                                <stop offset="0%" stop-color="#0D9488" />
                                <stop offset="100%" stop-color="#0EA5E9" />
                            </linearGradient>
                        </defs>
                        <!-- Left path from Profil-Card to Result-Hub -->
                        <path d="M 110 140 C 110 240, 200 240, 230 330" stroke="url(#pink-grad)" stroke-width="2.5" stroke-linecap="round" stroke-dasharray="6 8" class="animate-dash opacity-35" />
                        <!-- Right path from Engine-Card to Result-Hub -->
                        <path d="M 370 170 C 370 260, 280 260, 250 330" stroke="url(#lime-grad)" stroke-width="2.5" stroke-linecap="round" stroke-dasharray="6 8" class="animate-dash-reverse opacity-35" />
                    </svg>

                    <!-- Card 1: Input Profile (Top Left) -->
                    <div class="absolute left-2 top-8 w-[230px] bg-white/90 backdrop-blur-md border border-slate-200/80 rounded-2xl p-4.5 shadow-xl z-10 hover:scale-[1.03] transition-all duration-300 animate-float-soft">
                        <div class="flex items-center justify-between mb-3.5">
                            <span class="bg-[#0EA5E9]/15 text-[#0EA5E9] border border-[#0EA5E9]/25 text-[8px] font-black uppercase tracking-wider px-2.5 py-0.5 rounded-full">Profil</span>
                            <i data-lucide="users" class="w-3.5 h-3.5 text-slate-400"></i>
                        </div>
                        <h4 class="text-slate-900 text-xs font-black mb-1">3-Personen-Haushalt</h4>
                        <p class="text-slate-500 text-[10px] font-medium leading-tight mb-3">Mutter (34) & 2 Kinder (6, 9)</p>
                        
                        <div class="w-full h-[1px] bg-slate-100 my-3"></div>
                        
                        <div class="space-y-2.5 text-[9px] text-slate-500 font-bold">
                            <div class="flex justify-between items-center mb-1">
                                <span>Kaltmiete: 620 €</span>
                                <span class="text-[#0EA5E9]">Mietstufe IV</span>
                            </div>
                            <div class="w-full bg-slate-100 h-1.5 rounded-full overflow-hidden">
                                <div class="bg-[#0EA5E9] h-full w-3/4 rounded-full"></div>
                            </div>
                            <div class="flex justify-between items-center mt-2">
                                <span>Netto-Einkommen</span>
                                <span class="text-slate-900">2.100 € / mtl.</span>
                            </div>
                        </div>
                    </div>

                    <!-- Card 2: Engine calculations (Top Right) -->
                    <div class="absolute right-2 top-20 w-[220px] bg-white/90 backdrop-blur-md border border-slate-200/80 rounded-2xl p-4.5 shadow-xl z-10 hover:scale-[1.03] transition-all duration-300 animate-float-soft-reverse">
                        <div class="flex items-center justify-between mb-3.5">
                            <span class="bg-[#0D9488]/15 text-[#0D9488] border border-[#0D9488]/25 text-[8px] font-black uppercase tracking-wider px-2.5 py-0.5 rounded-full">Amtly Engine v4</span>
                            <div class="relative flex h-2 w-2">
                                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#0D9488] opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-2 w-2 bg-[#0D9488]"></span>
                            </div>
                        </div>
                        
                        <div class="space-y-2 font-mono text-[9px] text-slate-600">
                            <div class="flex items-center gap-1.5">
                                <span class="text-[#0D9488] font-bold">✓</span>
                                <span>Berechne Freibeträge SGB II</span>
                            </div>
                            <div class="flex items-center gap-1.5">
                                <span class="text-[#0D9488] font-bold">✓</span>
                                <span>Lookup Wohngeldtabelle 2026</span>
                            </div>
                            <div class="flex items-center gap-1.5">
                                <span class="text-[#0D9488] font-bold">✓</span>
                                <span>Heizkostenpauschale active</span>
                            </div>
                            <span class="text-[8px] font-bold text-[#0D9488]/80 block mt-2 animate-pulse">> engine.py: check_eligibility() ...</span>
                        </div>
                    </div>

                    <!-- Card 3: Eligibility Output Hub (Center Bottom) -->
                    <div class="absolute bottom-4 left-1/2 -translate-x-1/2 w-[340px] bg-white border-2 border-[#0D9488] rounded-[28px] p-5.5 shadow-[0_25px_60px_-15px_rgba(13,148,136,0.12)] z-20 hover:scale-[1.02] hover:shadow-[0_30px_70px_-10px_rgba(13,148,136,0.18)] transition-all duration-500 animate-float-medium">
                        <div class="flex justify-between items-center mb-3">
                            <span class="text-slate-500 text-[8px] font-black uppercase tracking-widest">Monatlicher Zuschuss</span>
                            <span class="bg-[#0D9488] text-white text-[7px] font-black uppercase px-2 py-0.5 rounded-full">Ergebnis</span>
                        </div>
                        
                        <div class="text-[2.75rem] font-black text-[#0D9488] tracking-tighter leading-none mb-1 select-none">
                            672,00 €
                        </div>
                        <p class="text-slate-800 text-[10px] font-bold leading-normal mb-4">Dein berechneter Anspruch pro Monat</p>
                        
                        <!-- Mini Breakdown grid -->
                        <div class="grid grid-cols-2 gap-2 mb-4">
                            <div class="bg-slate-50 border border-slate-100 rounded-xl p-2.5 text-left">
                                <span class="block text-slate-500 text-[7px] uppercase tracking-wider font-bold mb-0.5">Wohngeld</span>
                                <span class="text-slate-900 text-xs font-black">380,00 €</span>
                            </div>
                            <div class="bg-slate-50 border border-slate-100 rounded-xl p-2.5 text-left">
                                <span class="block text-slate-500 text-[7px] uppercase tracking-wider font-bold mb-0.5">Kinderzuschlag</span>
                                <span class="text-[#0EA5E9] text-xs font-black">292,00 €</span>
                            </div>
                        </div>

                        <!-- Generator Action Status -->
                        <div class="border-t border-slate-100 pt-3 flex items-center justify-between">
                            <div class="text-slate-500 text-[8px] flex items-center gap-1.5">
                                <span class="flex h-1.5 w-1.5 rounded-full bg-[#0D9488] animate-pulse"></span>
                                <span>Antrag_fertig.pdf generiert</span>
                            </div>
                            <span class="text-[#0EA5E9] hover:underline text-[9px] font-black flex items-center gap-0.5 cursor-pointer">
                                PDF Download
                                <i data-lucide="download" class="w-3 h-3 stroke-[2.5]"></i>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Hero Interaction Scripts -->
        <script>
            // --- Social Proof Counter Animation ---
            (function() {
                const el = document.getElementById('social-counter');
                if (!el) return;
                const target = 18423;
                const start = 17800;
                const duration = 1800;
                const startTime = performance.now();
                function step(now) {
                    const elapsed = now - startTime;
                    const progress = Math.min(elapsed / duration, 1);
                    // Ease-out cubic
                    const eased = 1 - Math.pow(1 - progress, 3);
                    const current = Math.round(start + (target - start) * eased);
                    el.textContent = current.toLocaleString('de-DE');
                    if (progress < 1) requestAnimationFrame(step);
                }
                // Start after a short delay so it's visible
                setTimeout(() => requestAnimationFrame(step), 400);
            })();

            // --- Micro-Commitment Selector ---
            document.querySelectorAll('.person-selector-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const persons = this.dataset.persons;

                    // Visual feedback: highlight selected
                    document.querySelectorAll('.person-selector-btn').forEach(b => {
                        b.classList.remove('border-[#0EA5E9]', 'bg-[#0EA5E9]/10', 'text-[#0EA5E9]',
                                           'border-[#0D9488]', 'bg-[#0D9488]/5', 'text-[#0D9488]', 'scale-[1.08]');
                        b.classList.add('border-slate-200', 'bg-white', 'text-slate-700');
                    });
                    this.classList.remove('border-slate-200', 'bg-white', 'text-slate-700');
                    this.classList.add('border-[#0EA5E9]', 'bg-[#0EA5E9]/10', 'text-[#0EA5E9]', 'scale-[1.08]');

                    // Fire custom event for SmartCalculator
                    document.dispatchEvent(new CustomEvent('amtly:preselect', { detail: { persons } }));

                    // Scroll to calculator
                    const calc = document.getElementById('calculator');
                    if (calc) calc.scrollIntoView({ behavior: 'smooth', block: 'start' });
                });
            });
        </script>

        <!-- Spacing container instead of dark-to-light gradient -->
        <div class="h-16 w-full bg-white relative z-10 border-none"></div>
 

         <!-- CALCULATOR SECTION -->
        <section id="calculator" class="w-full bg-white pb-24 pt-12 border-b border-slate-100 relative overflow-hidden">
            <!-- Background grids/glows -->
            <div class="absolute inset-0 bg-[linear-gradient(to_right,#f1f5f9_1px,transparent_1px),linear-gradient(to_bottom,#f1f5f9_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)] opacity-50"></div>
            
            <div class="relative z-10 max-w-3xl mx-auto px-6">
                <div class="text-center mb-12">
                    <span class="text-brand-blue text-sm font-bold uppercase tracking-wider mb-3 block">Anspruchs-Rechner</span>
                    <h2 class="text-3xl md:text-4xl font-sans font-bold text-slate-900 mb-4">Berechne deinen Anspruch in 2 Minuten</h2>
                    <p class="text-slate-600 text-base max-w-lg mx-auto font-light leading-relaxed">
                        Anonym und DSGVO-konform. Gib deine Daten ein, um sofort die für dich finanziell beste Sozialleistung zu ermitteln.
                    </p>
                </div>
                
                <!-- The Calculator Container -->
                <div class="bg-white p-8 md:p-12 rounded-[32px] border border-slate-200/60 shadow-[0_20px_50px_-12px_rgba(0,0,0,0.03)] text-left relative">
                    <div class="absolute -top-4 -right-4 w-24 h-24 bg-brand-blue/5 rounded-full blur-2xl"></div>
                    <SmartCalculator client:load />
                </div>
            </div>
        </section>

        <!-- PROCESS SECTION -->
        <div class="w-full bg-slate-50/50 pb-40 pt-24 relative overflow-hidden border-t border-slate-100">
            <!-- Decorative Elements -->
             <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#0EA5E9]/5 rounded-full blur-[140px] pointer-events-none"></div>
             <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-[#0D9488]/5 rounded-full blur-[120px] pointer-events-none"></div>

             <div class="max-w-7xl mx-auto px-6 mb-20 relative z-10">
                <div class="text-center mb-16">
                    <span class="text-[#0EA5E9] text-xs font-black uppercase tracking-widest mb-4 block">Der Ablauf</span>
                    <h2 class="text-4xl md:text-5xl font-sans font-black text-slate-900 mb-6">
                        Vom Anspruch zur <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#0EA5E9] to-[#0D9488]">Auszahlung.</span>
                    </h2>
                    <p class="text-slate-600 text-lg font-light max-w-2xl mx-auto leading-relaxed">
                        Wir begleiten dich nicht nur beim Rechnen, sondern bis das Geld auf deinem Konto ist.
                    </p>
                </div>

                <div class="process-grid grid md:grid-cols-4 gap-6">
                    <!-- Step 1 -->
                    <div class="process-card bg-white border border-slate-200/80 p-8 rounded-3xl relative group hover:shadow-xl hover:border-[#0D9488]/30 transition-all duration-300">
                         <div class="absolute -top-4 -right-4 w-10 h-10 bg-[#0D9488] text-white font-black flex items-center justify-center text-sm rounded-2xl shadow-lg shadow-[#0D9488]/20">1</div>
                         <div class="w-14 h-14 bg-slate-50 rounded-2xl flex items-center justify-center text-slate-800 mb-6 border border-slate-100">
                             <i data-lucide="calculator" class="w-6 h-6"></i>
                         </div>
                         <h3 class="text-xl font-sans font-black text-slate-900 mb-3">Check starten</h3>
                         <p class="text-sm text-slate-600 font-light leading-relaxed">
                             Beantworte in 2 Minuten einfache Fragen zu Einkommen, Wohnsituation und Familie. Anonym und ohne Anmeldung.
                         </p>
                    </div>

                    <!-- Step 2 -->
                    <div class="process-card bg-white border border-slate-200/80 p-8 rounded-3xl relative group hover:shadow-xl hover:border-slate-300 transition-all duration-300">
                         <div class="absolute -top-4 -right-4 w-10 h-10 bg-white border border-slate-200 text-slate-700 font-black flex items-center justify-center text-sm rounded-2xl shadow-md">2</div>
                         <div class="w-14 h-14 bg-slate-50 rounded-2xl flex items-center justify-center text-slate-800 mb-6 border border-slate-100">
                             <i data-lucide="layout-list" class="w-6 h-6"></i>
                         </div>
                         <h3 class="text-xl font-sans font-black text-slate-900 mb-3">Ergebnisse sehen</h3>
                         <p class="text-sm text-slate-600 font-light leading-relaxed">
                             Du siehst sofort alle Förderungen, die dir zustehen – Wohngeld, Bürgergeld, Kinderzuschlag & mehr – mit genauen Beträgen.
                         </p>
                    </div>

                    <!-- Step 3 -->

---
import { getCollection } from 'astro:content';
export const prerender = true;
import Layout from '../../layouts/layout.astro';
import SchemaOrg from '../../components/seo/seo-schema.astro';

export async function getStaticPaths() {
  const guideEntries = await getCollection('ratgeber');
  return guideEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const title = `${entry.data.title} | Sozialer Navigator Ratgeber`;
---

<Layout title={title} description={entry.data.description} type="article">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": entry.data.title,
    "description": entry.data.description,
    "author": {
      "@type": "Person",
      "name": entry.data.author
    },
    "datePublished": entry.data.pubDate.toISOString().split('T')[0],
    "image": entry.data.image ? `https://sozialer-navigator.de${entry.data.image}` : undefined
  })} slot="head" />

  <main class="min-h-screen bg-white text-slate-900 pt-32 pb-24 px-6 relative">
      
      <!-- Progress Bar (Reading) -->
      <div class="fixed top-0 left-0 w-full h-1 bg-slate-100 z-50">
          <div class="h-full bg-brand-gold w-0" id="scroll-progress"></div>
      </div>

      <article class="max-w-3xl mx-auto relative z-10">
          
          <!-- Header -->
          <div class="mb-12">
               <a href="/ratgeber/" class="group flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-slate-400 hover:text-[#0a1628] transition-colors mb-8">
                    <i data-lucide="arrow-left" class="w-4 h-4 group-hover:-translate-x-1 transition-transform"></i>
                    Zurück zur Übersicht
               </a>
               
               <div class="flex items-center gap-4 text-xs font-bold uppercase tracking-widest text-[#c5a67c] mb-6">
                   <span>{entry.data.tags ? entry.data.tags[0] : 'Ratgeber'}</span>
                   <span class="w-1 h-1 rounded-full bg-slate-300"></span>
                   <span>{entry.data.pubDate.toLocaleDateString('de-DE')}</span>
               </div>

               <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif text-[#0a1628] leading-[1.1] mb-8">
                   {entry.data.title}
               </h1>

               <p class="text-xl text-slate-600 font-light leading-relaxed border-l-4 border-[#c5a67c] pl-6 italic">
                   {entry.data.description}
               </p>
          </div>

          <!-- Content -->
          <div class="prose prose-slate prose-lg max-w-none prose-headings:font-serif prose-headings:text-[#0a1628] prose-a:text-[#0a1628] hover:prose-a:text-[#c5a67c] prose-strong:text-[#0a1628] prose-img:rounded-2xl prose-img:shadow-xl">
              <Content />
          </div>

          <!-- Author Box -->
          <div class="mt-16 pt-12 border-t border-slate-100 flex items-center gap-6">
              <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center text-2xl">
                  👨‍💻
              </div>
              <div>
                  <div class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-1">Verfasst von</div>
                  <div class="font-serif text-lg text-[#0a1628] font-bold">{entry.data.author}</div>
              </div>
          </div>

      </article>

  </main>
</Layout>

<script>
    // Scroll Progress
    window.addEventListener('scroll', () => {
        const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
        const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const scrolled = (winScroll / height) * 100;
        const bar = document.getElementById("scroll-progress");
        if(bar) bar.style.width = scrolled + "%";
    });
    
    if (window.lucide) {
        window.lucide.createIcons();
    }
</script>

<script is:inline>
  const counterEl = document.getElementById('live-counter');
  let count = Math.floor(Math.random() * (22 - 9 + 1)) + 9;
  setInterval(() => { count += Math.random() > 0.6 ? 1 : 0; if(counterEl) counterEl.innerText = `${count} Personen`; }, 4500);

  function runVisualQuickCheck() {
    const rc = document.getElementById('qc-result-container');
    const rt = document.getElementById('qc-result-text');
    rc.style.display = 'block';
    rt.innerHTML = `
      <div style="text-align: left; background: #ffffff; padding: 25px; border-radius: 20px; border: 2px solid #22c55e; width: 100%;">
        <h3 style="font-weight:900; color: #15803d; margin-top: 0;">🎯 Einschätzung: Positiv</h3>
        <p style="font-size: 0.95rem; color: #475569;">In Ihrer Mietstufe haben Sie hervorragende Aussichten. Sichern Sie jetzt die Frist (Weg A).</p>
        <a href="#generator" style="display: block; background: #2563eb; color: white; padding: 18px 24px; border-radius: 12px; text-decoration: none; font-weight: 800; margin-top: 15px; text-align: center;">JETZT ANSPRUCH SICHERN</a>
      </div>
    `;
    rc.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function copyToClipboard() {
    navigator.clipboard.writeText(document.getElementById('antragText').innerText).then(() => {
      document.getElementById('copyHint').innerText = "✓ TEXT KOPIERT – JETZT MAIL SENDEN";
    });
  }

  function nextStep(step) {
    document.getElementById('step-1').style.display = 'none';
    document.getElementById('step-2').style.display = 'none';
    document.getElementById('step-3').style.display = 'none';
    document.getElementById('step-' + step).style.display = 'block';
    if(step >= 2) document.getElementById('step-2-bar').style.background = '#2563eb';
    if(step >= 3) document.getElementById('step-3-bar').style.background = '#2563eb';
    document.getElementById('status-dashboard').scrollIntoView({ behavior: 'smooth' });
  }
</script>

<script>
  import { createClient } from '@supabase/supabase-js'
  const supabase = createClient('https://iiimjuplyjqapvwhbozf.supabase.co', 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImlpaW1qdXBseWpxYXB2d2hib3pmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjU2NTI4MTgsImV4cCI6MjA4MTIyODgxOH0.Ru-09I4PuFQsJC-AMcdntn9bCS2f9lOdGQoMo7fAHYs')

  const cForm = document.getElementById('supabase-lead-form') as HTMLFormElement;
  const cityTag = document.querySelector('h1')?.innerText.split('in ')[1]?.split(':')[0] || 'Unbekannt';

  cForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('c-submit-btn') as HTMLButtonElement;
    btn.innerText = 'Wird gesendet...';
    
    const jobStatus = (cForm.querySelector('input[name="job_status"]:checked') as HTMLInputElement)?.value;
    const needs = Array.from(cForm.querySelectorAll('input[name="needs"]:checked')).map(el => (el as HTMLInputElement).value).join(', ');
    
    const { error } = await supabase.from('leads').insert([{ 
      first_name: (document.getElementById('c-vorname') as HTMLInputElement).value, 
      last_name: (document.getElementById('c-nachname') as HTMLInputElement).value,
      email: (document.getElementById('c-email') as HTMLInputElement).value,
      lead_type: needs || 'General-Checkup',
      city: cityTag,
      status: 'neu',
      job_status: jobStatus, 
      notes: `Status: ${jobStatus} | Bedarfe: ${needs}` 
    }]);

    if (!error) {
      if (cForm) cForm.style.display = 'none';
      document.getElementById('progress-container')!.style.display = 'none';
      const successEl = document.getElementById('c-success');
      if (successEl) successEl.style.display = 'block';
    }
  });
</script>
---
// src/pages/ueber-uns.astro - Amtly 2026
import Layout from '../layouts/layout.astro';
import SchemaOrg from '../components/seo/seo-schema.astro';
import '../styles/global.css';

const title = "Unsere Mission & Vision | Amtly";
const description = "Wir demokratisieren den Zugang zu sozialen Rechten durch Technologie. Erfahren Sie mehr über unsere Vision bei Amtly.";
---

<Layout title={title} description={description} activePage="ueber-uns">
    <fragment slot="head">
        <SchemaOrg 
            type="BreadcrumbList" 
            data={{
                items: [
                    { name: "Startseite", url: "/" },
                    { name: "Über uns", url: "/ueber-uns" }
                ]
            }}
        />

    </fragment>
  
    <main class="min-h-screen bg-slate-50 pt-0 pb-32">
        
        <!-- HERO SECTION (Amtly Fintech Style) -->
        <section class="relative pt-40 pb-32 px-6 overflow-hidden bg-slate-900 text-left">
             <!-- Grainy Overlay & Background Glow -->
             <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-5 mix-blend-soft-light pointer-events-none"></div>
             <div class="absolute top-0 right-1/4 w-[400px] h-[400px] bg-teal-500/10 rounded-full blur-[120px] pointer-events-none"></div>
             
             <div class="max-w-5xl mx-auto relative z-10">
                 <div class="inline-flex items-center gap-2 mb-6 px-4 py-2 rounded-full bg-teal-500/10 border border-teal-500/20 backdrop-blur-sm">
                     <span class="flex h-2 w-2 rounded-full bg-teal-500 animate-pulse"></span>
                     <span class="text-teal-400 text-xs font-semibold tracking-wider uppercase">Wer wir sind</span>
                 </div>
                 <h1 class="text-5xl md:text-7xl font-sans font-bold text-white mb-8 leading-[1.1] tracking-tight">
                    Demokratischer Zugang <br/>
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-teal-400 to-sky-400">zu deinem Recht.</span>
                 </h1>
                 <p class="text-xl text-slate-300 font-light max-w-2xl leading-relaxed">
                    Amtly schließt die Lücke zwischen komplexer Bürokratie und deinen echten gesetzlichen Ansprüchen. Unabhängig, präzise und zu 100 % digital.
                 </p>
             </div>
        </section>

        <!-- MISSION & VISION SECTOR (Fintech Bento Grid) -->
        <section class="py-24 px-6 relative z-20 -mt-10">
            <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-8 items-stretch">
                
                <!-- Card 1: MISSION -->
                <div class="bg-white border border-slate-200/80 rounded-[2.5rem] p-10 md:p-12 shadow-xl shadow-slate-200/30 flex flex-col justify-between hover:shadow-2xl transition-all duration-500 relative overflow-hidden group">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-teal-500/5 rounded-full blur-3xl pointer-events-none"></div>
                    
                    <div>
                        <div class="w-14 h-14 bg-teal-500/10 border border-teal-500/20 rounded-2xl flex items-center justify-center text-teal-600 mb-8 shadow-inner group-hover:scale-110 transition-transform duration-300">
                            <i data-lucide="target" class="w-7 h-7"></i>
                        </div>
                        
                        <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Unsere Mission</h2>
                        
                        <p class="text-slate-600 leading-relaxed text-base font-light space-y-4">
                            Staatliche Hilfe ist ein Recht, kein Almosen. Jedes Jahr bleiben jedoch Milliarden Euro an Zuschüssen ungenutzt, weil Anträge zu kompliziert sind oder Rechte schlicht unbekannt bleiben.
                        </p>
                        <p class="text-slate-600 leading-relaxed text-base font-light mt-4">
                            <strong>Wir ändern das.</strong> Unsere Mission ist es, den Zugang zu Ihren sozialen Ansprüchen radikal zu vereinfachen. Wir übersetzen Amtsdeutsch in einfache Fragen und befüllen offizielle Formulare vollautomatisch – damit Sie ohne Hürden bekommen, was Ihnen gesetzlich zusteht.
                        </p>
                    </div>
                    
                    <div class="mt-8 pt-6 border-t border-slate-100 flex items-center gap-3">
                        <span class="text-xs font-bold uppercase tracking-widest text-teal-600">Unkompliziert · Anonym · Schnell</span>
                    </div>
                </div>

                <!-- Card 2: VISION -->
                <div class="bg-slate-900 border border-slate-800 rounded-[2.5rem] p-10 md:p-12 shadow-2xl flex flex-col justify-between hover:shadow-slate-950/20 transition-all duration-500 relative overflow-hidden group">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-sky-500/5 rounded-full blur-3xl pointer-events-none"></div>
                    
                    <div>
                        <div class="w-14 h-14 bg-white/5 border border-white/10 rounded-2xl flex items-center justify-center text-teal-400 mb-8 shadow-inner group-hover:scale-110 transition-transform duration-300">
                            <i data-lucide="compass" class="w-7 h-7"></i>
                        </div>
                        
                        <h2 class="font-serif text-3xl font-bold text-white mb-6">Unsere Vision</h2>
                        
                        <p class="text-slate-300 leading-relaxed text-base font-light space-y-4">
                            Wir glauben an eine barrierefreie, unbürokratische Gesellschaft, in der jeder Mensch seine berechtigten Ansprüche mit wenigen Klicks und ohne juristische Barrieren geltend machen kann.
                        </p>
                        <p class="text-slate-300 leading-relaxed text-base font-light mt-4">
                            Amtly soll die führende, unabhängige Infrastruktur für soziale Gerechtigkeit im digitalen Zeitalter werden. Durch die Verbindung von smarter Berechnung und Zero-Knowledge-Sicherheit schaffen wir das vertrauenswürdigste Portal für Ihre staatlichen Fördermittel.
                        </p>
                    </div>
                    
                    <div class="mt-8 pt-6 border-t border-white/5 flex items-center gap-3">
                        <span class="text-xs font-bold uppercase tracking-widest text-teal-400">Barrierefrei · Transparent · Unabhängig</span>
                    </div>
                </div>

            </div>
        </section>

        <!-- PRINCIPLES GRID -->
        <section class="bg-white py-24 px-6 border-y border-slate-200/60">
            <div class="max-w-6xl mx-auto">
                <div class="text-center mb-20 max-w-3xl mx-auto">
                     <span class="text-teal-600 text-sm font-bold uppercase tracking-wider mb-4 block">Unsere Werte</span>
                     <h2 class="text-4xl font-sans font-bold text-slate-900 mb-4">Nach welchen Werten wir arbeiten.</h2>
                     <div class="w-24 h-1 bg-teal-500/20 rounded-full mx-auto"></div>
                </div>

                <div class="grid md:grid-cols-2 gap-8">
                    <!-- Value 1 -->
                    <div class="bg-slate-50 p-8 rounded-3xl border border-slate-200/50 hover:shadow-lg transition-all duration-300 text-left">
                        <div class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center text-teal-600 mb-6 shadow-sm border border-slate-100">
                            <i data-lucide="shield-check" class="w-6 h-6"></i>
                        </div>
                        <h3 class="text-xl font-bold text-slate-900 mb-3">Absolute Unabhängigkeit</h3>
                        <p class="text-slate-600 font-light leading-relaxed text-sm">
                            Wir sind keine staatliche Behörde, sondern ein unabhängiger Technologieträger. Wir stehen zu 100 % auf Ihrer Seite und helfen Ihnen, Ihre Rechte unvoreingenommen und beweissicher geltend zu machen.
                        </p>
                    </div>

                    <!-- Value 2 -->
                    <div class="bg-slate-50 p-8 rounded-3xl border border-slate-200/50 hover:shadow-lg transition-all duration-300 text-left">
                        <div class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center text-teal-600 mb-6 shadow-sm border border-slate-100">
                             <i data-lucide="lock" class="w-6 h-6"></i>
                        </div>
                        <h3 class="text-xl font-bold text-slate-900 mb-3">Zero-Knowledge Privatsphäre</h3>
                        <p class="text-slate-600 font-light leading-relaxed text-sm">
                            Ihre Daten gehören ausschließlich Ihnen. Der PDF-Ausfüll-Assistent arbeitet komplett lokal im Browser Ihres Geräts. Sensible Daten wie Name, Anschrift oder IBAN werden niemals an unsere Server übertragen.
                        </p>
                    </div>

                    <!-- Value 3 -->
                    <div class="bg-slate-50 p-8 rounded-3xl border border-slate-200/50 hover:shadow-lg transition-all duration-300 text-left">
                         <div class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center text-teal-600 mb-6 shadow-sm border border-slate-100">
                             <i data-lucide="calendar" class="w-6 h-6"></i>
                        </div>
                        <h3 class="text-xl font-bold text-slate-900 mb-3">Aktuellste Gesetzgebung 2026</h3>
                        <p class="text-slate-600 font-light leading-relaxed text-sm">
                            Das Sozialrecht ändert sich ständig. Unser smarter Berechnungs-Algorithmus wird fortlaufend gewartet und auf Basis der neuesten bundes- und landesrechtlichen Regelsätze sowie Mietstufen aktualisiert.
                        </p>
                    </div>

                    <!-- Value 4 -->
                    <div class="bg-slate-50 p-8 rounded-3xl border border-slate-200/50 hover:shadow-lg transition-all duration-300 text-left">
                        <div class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center text-teal-600 mb-6 shadow-sm border border-slate-100">
                            <i data-lucide="badge-percent" class="w-6 h-6"></i>
                        </div>
                        <h3 class="text-xl font-bold text-slate-900 mb-3">100% Kostenloser Check</h3>
                        <p class="text-slate-600 font-light leading-relaxed text-sm">
                            Der Zugang zu Information darf kein Privileg sein. Daher bleibt der komplette Universal-Fördercheck sowie das lokale Ausfüllen der PDFs für jeden Nutzer stets kostenfrei und ohne Anmeldung nutzbar.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA / DISCLAIMER -->
        <section class="max-w-4xl mx-auto px-6 mt-24 text-left">
             <div class="bg-slate-900 text-white p-8 md:p-12 rounded-[2rem] border border-slate-800 shadow-xl relative overflow-hidden">
                 <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-5 mix-blend-soft-light pointer-events-none"></div>
                 <div class="flex items-start gap-6 relative z-10">
                     <div class="shrink-0 text-teal-400">
                         <i data-lucide="info" class="w-8 h-8"></i>
                     </div>
                     <div>
                        <h3 class="text-lg font-bold uppercase tracking-wider mb-2 text-teal-400">Rechtlicher Hinweis</h3>
                        <p class="text-slate-300 font-light leading-relaxed text-sm">
                            Amtly ist ein privatwirtschaftlicher, unabhängiger Dienstleister und keine Behörde der Stadtverwaltung oder des Bundes. Wir bieten eine automatisierte Orientierungshilfe an. Unsere Berechnungen dienen der Information und stellen keine formelle Rechtsberatung dar.
                        </p>
                     </div>
                 </div>
             </div>
        </section>

    </main>

    <script is:inline src="/scripts/lucide.min.js"></script>
    <script is:inline>
        if (window.lucide) window.lucide.createIcons();
        document.addEventListener('astro:page-load', () => {
            if (window.lucide) window.lucide.createIcons();
        });
    </script>

</Layout>

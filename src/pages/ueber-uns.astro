---
import Layout from '../layouts/layout.astro';
import SchemaOrg from '../components/seo/seo-schema.astro';
import '../styles/global.css';

const title = "Unsere Kanzlei-Mission | Sozialer Navigator";
const description = "Unabhängigkeit, Expertise und Rechtsdurchsetzung. Wir kämpfen für Ihre Ansprüche im Sozialrecht.";
---

<Layout title={title} description={description} activePage="ueber-uns">
    <fragment slot="head">
        <SchemaOrg 
            type="BreadcrumbList" 
            data={{
                items: [
                    { name: "Startseite", url: "/" },
                    { name: "Über uns", url: "/ueber-uns" }
                ]
            }}
        />
    </fragment>
  
    <main class="min-h-screen bg-[#FDFDFD] pt-0 pb-32">
        
        <!-- HERO SECTION -->
        <section class="relative pt-40 pb-32 px-6 overflow-hidden bg-[#0a1628]">
            <!-- Subtle Background Texture -->
             <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-10 mix-blend-soft-light pointer-events-none"></div>
             
             <div class="max-w-5xl mx-auto relative z-10 text-center">
                 <span class="text-[#c5a67c] text-xs font-bold uppercase tracking-[0.2em] mb-6 block">
                    Über uns
                 </span>
                 <h1 class="text-5xl md:text-7xl font-serif text-white mb-8 leading-[1.1] tracking-tight">
                    Recht muss <br/>
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#c5a67c] to-[#e5cca5]">Recht bleiben.</span>
                 </h1>
                 <p class="text-xl text-slate-400 font-light max-w-2xl mx-auto leading-relaxed">
                    Der Soziale Navigator ist die Schnittstelle zwischen bürokratischer Komplexität und Ihrem Rechtsanspruch. Unabhängig, präzise und durchsetzungsstark.
                 </p>
             </div>
        </section>

        <!-- MISSION STATEMENT -->
        <section class="py-24 px-6">
            <div class="max-w-4xl mx-auto">
                <div class="border-l-4 border-[#c5a67c] pl-8 py-2">
                    <p class="text-2xl md:text-3xl font-serif text-[#0a1628] leading-relaxed italic">
                        "Soziale Sicherheit ist kein Almosen, sondern ein verbrieftes Recht. Wir sorgen dafür, dass dieses Recht nicht an Formularen scheitert."
                    </p>
                </div>
                
                <div class="mt-16 prose prose-lg text-slate-600 leading-relaxed font-light">
                    <p>
                        Jedes Jahr bleiben Milliarden Euro an staatlichen Hilfen ungenutzt. Nicht, weil der Bedarf fehlt, sondern weil der Zugang versperrt ist durch unverständliche Anträge, fehlerhafte Bescheide und behördliche Hürden.
                    </p>
                    <p>
                        Wir verstehen uns nicht nur als Rechner, sondern als Ihr digitaler Rechtsbeistand. Wir übersetzen Gesetze in Algorithmen und Bürokratie in verständliche Handlungsschritte.
                    </p>
                </div>
            </div>
        </section>

        <!-- VALUES GRID -->
        <section class="bg-[#f7f8fa] py-24 px-6 border-y border-slate-200">
            <div class="max-w-6xl mx-auto">
                <div class="text-center mb-16">
                    <h2 class="text-3xl md:text-4xl font-serif text-[#0a1628] mb-4">Unsere Prinzipien</h2>
                    <div class="w-24 h-[1px] bg-[#0a1628]/10 mx-auto"></div>
                </div>

                <div class="grid md:grid-cols-2 gap-12">
                    <!-- Value 1 -->
                    <div class="bg-white p-10 border-t-4 border-[#0a1628] shadow-lg shadow-black/5 hover:-translate-y-1 transition-transform duration-500">
                        <div class="w-12 h-12 bg-[#0a1628] text-white flex items-center justify-center mb-6 rounded-sm">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                        </div>
                        <h3 class="text-xl font-bold uppercase tracking-wider text-[#0a1628] mb-4">Unabhängigkeit</h3>
                        <p class="text-slate-600 font-light leading-relaxed">
                            Wir sind keine Behörde und werden nicht vom Staat finanziert. Wir stehen ausschließlich auf Ihrer Seite und prüfen Bescheide neutral und kritisch auf jeden Fehler.
                        </p>
                    </div>

                    <!-- Value 2 -->
                    <div class="bg-white p-10 border-t-4 border-[#c5a67c] shadow-lg shadow-black/5 hover:-translate-y-1 transition-transform duration-500">
                        <div class="w-12 h-12 bg-[#c5a67c] text-[#0a1628] flex items-center justify-center mb-6 rounded-sm">
                             <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
                        </div>
                        <h3 class="text-xl font-bold uppercase tracking-wider text-[#0a1628] mb-4">Datenschutz & Diskretion</h3>
                        <p class="text-slate-600 font-light leading-relaxed">
                            Ihre finanzielle Situation geht niemanden etwas an. Analysen erfolgen lokal ("Client-Side"). Wir speichern keine persönlichen Daten ohne Ihren expliziten Auftrag.
                        </p>
                    </div>

                    <!-- Value 3 -->
                    <div class="bg-white p-10 border-t-4 border-[#0a1628] shadow-lg shadow-black/5 hover:-translate-y-1 transition-transform duration-500">
                         <div class="w-12 h-12 bg-[#0a1628] text-white flex items-center justify-center mb-6 rounded-sm">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="m9 16 2 2 4-4"/></svg>
                        </div>
                        <h3 class="text-xl font-bold uppercase tracking-wider text-[#0a1628] mb-4">Aktuelle Rechtslage 2026</h3>
                        <p class="text-slate-600 font-light leading-relaxed">
                            Gesetze ändern sich ständig. Unsere Datenbanken und Algorithmen werden täglich aktualisiert, um die neuesten Urteile und Sätze (Stand: 2026) zu berücksichtigen.
                        </p>
                    </div>

                    <!-- Value 4 -->
                    <div class="bg-white p-10 border-t-4 border-[#c5a67c] shadow-lg shadow-black/5 hover:-translate-y-1 transition-transform duration-500">
                        <div class="w-12 h-12 bg-[#c5a67c] text-[#0a1628] flex items-center justify-center mb-6 rounded-sm">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                        </div>
                        <h3 class="text-xl font-bold uppercase tracking-wider text-[#0a1628] mb-4">Kostenlose Ersteinschätzung</h3>
                        <p class="text-slate-600 font-light leading-relaxed">
                            Der Zugang zum Recht darf keine Frage des Geldbeutels sein. Deshalb ist die Nutzung unserer Rechner und die Ersteinschätzung für Sie immer kostenlos.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA / DISCLAIMER -->
        <section class="max-w-4xl mx-auto px-6 mt-20">
             <div class="bg-[#0a1628] text-white p-8 md:p-12 rounded-sm border border-[#c5a67c]">
                 <div class="flex items-start gap-6">
                     <div class="shrink-0 text-[#c5a67c]">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                     </div>
                     <div>
                        <h3 class="text-lg font-bold uppercase tracking-wider mb-2 text-[#c5a67c]">Rechtlicher Hinweis</h3>
                        <p class="text-slate-300 font-light leading-relaxed">
                            Wir sind ein unabhängiger Dienstleister und keine staatliche Behörde. Rechtsverbindliche Auskünfte erhalten Sie ausschließlich bei Ihrem zuständigen Jobcenter oder Wohngeldamt. Unsere Berechnungen dienen als fundierte Orientierungshilfe.
                        </p>
                     </div>
                 </div>
             </div>
        </section>

    </main>

</Layout>

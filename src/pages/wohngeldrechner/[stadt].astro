---
// src/pages/wohngeldrechner/[stadt].astro
import Layout from '../../layouts/Layout.astro';
export const prerender = true;
// SchemaOrg removed for legacy page
import { wohngeldData } from '../../data/wohngeldData.js';
import { SmartCalculator } from '../../components/SmartCalculator.jsx'; // Kept only for visual teaser if needed, or we can remove. Let's keep it as specific requested "Teaser + CTA" might imply just a button, but user said "Simplified content (Teaser + CTA)". I will use a strong visual card instead of the full calculator to force the click.

export function getStaticPaths() {
  return wohngeldData.filter(item => item.slug).map((item) => ({ 
    params: { stadt: item.slug },
    props: { info: item },
  }));
}

const { info } = Astro.props;

const stadtName = info?.stadt || "Deine Stadt";
const mietstufe = info?.mietstufe || 1;
// const amtName = info?.amt_name || "Wohngeldbehörde"; // Removed unused

// Updated canonical to point to the new structure
const canonicalUrl = `https://sozialer-navigator.de/${info.slug}/wohngeld/`;

const seoTitle = `Wohngeldrechner ${stadtName} - Jetzt auf der Hauptseite`;
const seoDesc = `Der Wohngeldrechner für ${stadtName} ist umgezogen. Bitte nutzen Sie die neue, aktuelle Seite mit allen Infos für 2026.`;

---

<Layout title={seoTitle} description={seoDesc} canonical={canonicalUrl}>
    <fragment slot="head">
        <meta name="robots" content="noindex, follow" />
    </fragment>

    <main class="min-h-screen bg-[#F8FAFC] text-slate-900 pt-32 pb-24 px-6 relative overflow-hidden flex items-center justify-center">
        
         <!-- Background Elements -->
        <div class="absolute top-0 left-0 w-full h-[500px] bg-gradient-to-b from-blue-50 to-transparent pointer-events-none"></div>

        <div class="max-w-2xl mx-auto text-center relative z-10 space-y-8">
            
            <div class="inline-flex items-center gap-2 bg-blue-50 border border-blue-100 px-4 py-1.5 rounded-full text-xs font-bold uppercase text-blue-600 tracking-widest">
                <i data-lucide="info" class="w-4 h-4"></i> Seite umgezogen
            </div>

            <h1 class="text-4xl md:text-5xl font-black text-slate-900 tracking-tight">
                Der Wohngeldrechner für <br/>
                <span class="text-blue-600">{stadtName}</span> ist jetzt hier:
            </h1>
            
            <p class="text-slate-600 text-lg leading-relaxed">
                Wir haben unsere Daten aktualisiert. Für die offizielle Berechnung (Stand 2026) und lokale Antragsformulare nutzen Sie bitte unsere neue Hauptseite.
            </p>

            <a href={canonicalUrl} class="inline-flex items-center gap-3 bg-blue-600 hover:bg-blue-700 text-white text-lg font-bold px-8 py-4 rounded-2xl shadow-lg hover:shadow-blue-500/20 transition-all transform hover:-translate-y-1">
                <span>Zum neuen Wohngeldrechner</span>
                <i data-lucide="arrow-right" class="w-5 h-5"></i>
            </a>
            
            <p class="text-sm text-slate-400 mt-8">
                Sie werden in Kürze automatisch weitergeleitet...
            </p>
            <meta http-equiv="refresh" content={`3;url=${canonicalUrl}`} />
        </div>
    </main>
</Layout>

<script>
    import { createIcons, Info, ArrowRight } from 'lucide';
    createIcons({
        icons: {
            Info,
            ArrowRight
        }
    });
</script>

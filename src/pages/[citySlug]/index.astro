---
import Layout from '../../layouts/Layout.astro';
import cities from '../../data/cities_2026.json';
import SchemaOrg from '../../components/SEO/SeoSchema.astro';
import Faq from '../../components/Faq.astro';

export const prerender = true;

export async function getStaticPaths() {
  return cities.map((city) => ({
    params: { citySlug: city.slug },
    props: { city },
  }));
}

const { city } = Astro.props;

const cityFaqs = [
  {
    question: `Wo beantrage ich Wohngeld in ${city.stadt}?`,
    answer: `Die Zuständigkeit liegt bei der ${city.amt_name || 'lokalen Wohngeldbehörde'}. Sie finden die Stelle in der ${city.amt_adresse || 'Stadtverwaltung'}.`
  },
  {
    question: `Wie hoch ist die Miete in ${city.stadt} (Mietstufe)?`,
    answer: `${city.stadt} ist der Mietstufe ${city.mietstufe} zugeordnet. Dies beeinflusst die Höhe Ihres Wohngeldanspruchs. Je höher die Stufe, desto höher der Zuschuss.`
  },
  {
    question: `Kann ich in ${city.stadt} Bürgergeld beantragen?`,
    answer: `Ja, das Jobcenter ${city.stadt} ist für Bürgergeld (ehemals Hartz 4) zuständig. Den Antrag können Sie oft auch online stellen.`
  },
  {
    question: `Gibt es einen Wohngeldrechner für ${city.stadt}?`,
    answer: `Ja, unser Rechner ist speziell auf die Mietstufe ${city.mietstufe} von ${city.stadt} eingestellt und liefert Ihnen eine genaue Schätzung.`
  }
];

const faqSchemaItems = cityFaqs.map(item => ({ q: item.question, a: item.answer }));
---

<Layout title={`Sozialer Navigator ${city.stadt}: Wohngeld & Bürgergeld 2026`} description={`Ihr Wegweiser für soziale Leistungen in ${city.stadt}. Prüfen Sie Anspruch auf Wohngeld und Bürgergeld.`}>
  <main class="min-h-screen bg-[#F8FAFC] text-slate-900 pt-32 pb-24 px-6 relative overflow-hidden">
     
     <!-- Background Elements -->
     <div class="absolute top-0 left-0 w-full h-[500px] bg-gradient-to-b from-blue-50 to-transparent pointer-events-none"></div>
     <div class="absolute top-20 right-0 w-[500px] h-[500px] bg-blue-100 rounded-full blur-3xl pointer-events-none opacity-50"></div>

     <div class="max-w-5xl mx-auto relative z-10">
        <header class="text-left space-y-6 mb-16">
            <a href="/" class="text-xs font-bold text-slate-500 uppercase flex items-center gap-2 hover:text-blue-600 transition-colors">
              <i data-lucide="arrow-left" class="w-4 h-4"></i> Startseite
            </a>
            
            <fragment slot="head">
                <SchemaOrg 
                    type="GovernmentService" 
                    data={{
                        city: city.stadt,
                        url: `https://sozialer-navigator.de/${city.slug}/`,
                        authorityName: city.amt_name || `Stadtverwaltung ${city.stadt}`,
                        address: city.amt_adresse ? city.amt_adresse.split(',')[0] : undefined,
                        zip: city.plz
                    }}
                />
                 <SchemaOrg 
                    type="BreadcrumbList" 
                    data={{
                        items: [
                            { name: "Startseite", url: "/" },
                            { name: city.stadt, url: `/${city.slug}/` }
                        ]
                    }}
                />
                <SchemaOrg 
                    type="FAQPage" 
                    data={{ items: faqSchemaItems }}
                />
            </fragment>

            <div>
                <div class="inline-flex items-center gap-2 bg-white border border-slate-200 shadow-sm rounded-full px-4 py-1.5 mb-6">
                    <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
                    <span class="text-xs font-bold uppercase tracking-widest text-blue-700">Regionaler Wegweiser</span>
                </div>
                <h1 class="text-4xl md:text-6xl font-bold text-slate-900 tracking-tight mb-4">
                  Sozialer Navigator <br/>
                  <span class="text-blue-600">{city.stadt}</span>
                </h1>
                <p class="text-slate-600 font-medium leading-relaxed text-lg max-w-2xl">
                   Finden Sie lokale Anlaufstellen, prüfen Sie Ihre Ansprüche und erhalten Sie Unterstützung bei Anträgen in {city.stadt}.
                </p>
            </div>
        </header>

         <div class="grid md:grid-cols-2 gap-8 mb-24">
            <!-- Wohngeld Card -->
            <a href={`/${city.slug}/wohngeld/`} class="group relative block p-10 overflow-hidden bg-white border border-slate-200 rounded-3xl shadow-sm hover:shadow-xl transition-all">
               <!-- Card Background (Hover) -->
               <div class="absolute inset-0 bg-blue-50 opacity-0 group-hover:opacity-100 transition-opacity -z-10"></div>
               
               <div class="relative z-10 flex flex-col h-full">
                   <div class="flex items-center justify-between mb-8">
                      <div class="w-14 h-14 bg-blue-50 rounded-xl flex items-center justify-center text-blue-600 border border-blue-100 group-hover:scale-110 transition-transform duration-300">
                         <i data-lucide="home" class="w-7 h-7"></i>
                      </div>
                      <div class="bg-slate-50 rounded-full p-2 text-slate-400 group-hover:text-blue-600 group-hover:bg-blue-100 transition-all">
                        <i data-lucide="arrow-right" class="w-5 h-5"></i>
                      </div>
                   </div>
                   
                   <h3 class="text-3xl font-bold text-slate-900 mb-4 group-hover:text-blue-700 transition-colors">Wohngeld</h3>
                   <p class="text-slate-600 leading-relaxed mb-auto">
                      Zuschuss zur Miete für Geringverdiener. Prüfen Sie, ob Ihnen Wohngeld in {city.stadt} zusteht – im Schnitt winken 370 € monatlich!
                   </p>
                   
                   <div class="mt-8 pt-6 border-t border-slate-100">
                        <span class="text-xs font-bold uppercase tracking-widest text-blue-600">
                            Mietstufe {city.mietstufe}
                        </span>
                   </div>
               </div>
            </a>

            <!-- Bürgergeld Card -->
            <a href={`/${city.slug}/grundsicherung/`} class="group relative block p-10 overflow-hidden bg-white border border-slate-200 rounded-3xl shadow-sm hover:shadow-xl transition-all">
               <!-- Card Background (Hover) -->
               <div class="absolute inset-0 bg-indigo-50 opacity-0 group-hover:opacity-100 transition-opacity -z-10"></div>
               
               <div class="relative z-10 flex flex-col h-full">
                   <div class="flex items-center justify-between mb-8">
                      <div class="w-14 h-14 bg-indigo-50 rounded-xl flex items-center justify-center text-indigo-600 border border-indigo-100 group-hover:scale-110 transition-transform duration-300">
                         <i data-lucide="briefcase" class="w-7 h-7"></i>
                      </div>
                      <div class="bg-slate-50 rounded-full p-2 text-slate-400 group-hover:text-indigo-600 group-hover:bg-indigo-100 transition-all">
                        <i data-lucide="arrow-right" class="w-5 h-5"></i>
                      </div>
                   </div>
                   
                   <h3 class="text-3xl font-bold text-slate-900 mb-4 group-hover:text-indigo-700 transition-colors">Bürgergeld</h3>
                   <p class="text-slate-600 leading-relaxed mb-auto">
                      Grundsicherung für Arbeitssuchende. Finden Sie Ihr Jobcenter in {city.stadt}.
                   </p>
                   
                   <div class="mt-8 pt-6 border-t border-slate-100">
                        <span class="text-xs font-bold uppercase tracking-widest text-indigo-600">
                            Jobcenter
                        </span>
                   </div>
               </div>
            </a>
         </div>

         <!-- LOCAL SEO CONTENT HUB -->
         <div class="bg-white rounded-3xl shadow-sm border border-slate-200 p-8 md:p-12 mb-12">
              <div class="mb-10">
                  <span class="text-blue-600 text-xs font-bold uppercase tracking-[0.2em] mb-3 block">Lokaler Ratgeber</span>
                  <h2 class="text-2xl md:text-3xl font-serif text-slate-900 mb-4">
                      Ihr Wegweiser für Sozialleistungen in {city.stadt} ({city.plz})
                  </h2>
                  <div class="w-16 h-[2px] bg-blue-600"></div>
              </div>

              <div class="prose prose-slate max-w-none prose-headings:font-serif prose-headings:text-slate-900 prose-p:text-slate-600 prose-p:leading-relaxed">
                  
                  <p>
                      Die Beantragung von staatlichen Hilfen zur Sicherung des Lebensunterhalts kann komplex sein – besonders aufgrund der starken regionalen Unterschiede. Wenn Sie in <strong>{city.stadt}</strong> leben und Unterstützung bei Ihren Wohn- oder Lebenshaltungskosten benötigen, stehen Ihnen grundsätzlich zwei Wege offen: Das Wohngeld als reiner Mietzuschuss oder das Bürgergeld (ehemals Hartz IV) als vollumfängliche Grundsicherung.
                  </p>

                  <h3>Die Bedeutung der Mietstufe in {city.stadt}</h3>
                  <p>
                      Eine der wichtigsten Variablen bei der Berechnung Ihres Wohngeldanspruchs ist die lokale Mietstufe. Der Gesetzgeber bewertet die Wohnkosten in Deutschland regional unterschiedlich. <strong>{city.stadt}</strong> ist aktuell der <strong>Mietstufe {city.mietstufe}</strong> zugeordnet. Diese Einstufung bestimmt maßgeblich, bis zu welchem Höchstbetrag Ihre tatsächliche Bruttokaltmiete bei der Wohngeldberechnung bezuschusst wird. Unser integrierter Rechner für {city.stadt} hat diese Werte bereits vollautomatisch für Sie hinterlegt, um eine punktgenaue Überprüfung zu ermöglichen.
                  </p>

                  <h3>Zuständigkeiten vor Ort: {city.amt_name || "Die Wohngeldstelle"}</h3>
                  <p>
                      Sollte unser Rechner für Sie einen positiven Wohngeldanspruch in Höhe des durchschnittlichen Zuschusses (oft um die 370 €) ermitteln, ist der nächste Schritt die formelle Beantragung. Die Zuständigkeit liegt hierbei bei der lokalen Behörde in {city.stadt}. 
                      {city.amt_name && city.amt_adresse ? `Konkret können Sie sich an das ${city.amt_name} unter der Adresse ${city.amt_adresse.split(',')[0]} wenden.` : `Bitte wenden Sie sich hierfür an die zuständige Stadt- oder Gemeindeverwaltung in ${city.stadt}.`} Es ist ratsam, dem Antrag direkt alle notwendigen Gehalts- und Mietnachweise beizufügen, um die Bearbeitungszeit zu verkürzen.
                  </p>

                  <h3>Bürgergeld oder Wohngeld?</h3>
                  <p>
                      Oft herrscht Unklarheit darüber, welche Leistung beantragt werden sollte. Ein wichtiger rechtlicher Grundsatz lautet: Wohngeld geht dem Bürgergeld vor. Reicht Ihr Haushaltseinkommen (inkl. z.B. Kinderzuschlag) aus, um den eigenen Bedarf zu decken, aber nicht für die Miete in {city.stadt}, dann ist die <strong>Wohngeldstelle</strong> Ihr Ansprechpartner. Liegt Ihr Einkommen jedoch generell unter dem Existenzminimum, fällt die Zuständigkeit an das <strong>Jobcenter {city.stadt}</strong> für Leistungen nach dem SGB II.
                  </p>
                  
              </div>
         </div>

     </div>
  </main>
  
  <Faq items={cityFaqs} />
</Layout>

<script>
    function initIcons() {
        if (window.lucide) {
            window.lucide.createIcons();
        }
    }
    initIcons();
    document.addEventListener('astro:page-load', initIcons);
</script>

<style>
/* Reusing global styles, but defining pro-card locally just in case */
.pro-card {
    background: #ffffff;
    border: 1px solid rgba(0,0,0,0.04);
    border-radius: 2rem;
    box-shadow: 0 20px 40px -10px rgba(0,0,0,0.08);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.2s;
}
</style>

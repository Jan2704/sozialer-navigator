---
import Layout from '../layouts/layout.astro';
import NoticeCheckQuiz from '../components/notice-check-quiz.tsx';
import LeadModal from '../components/lead-modal.astro';

---

<Layout 
  title="Bürgergeld-Bescheid prüfen | Kostenlose Ersteinschätzung"
  description="Lassen Sie Ihren Bescheid von Experten prüfen. Finden wir Fehler, legen wir Widerspruch ein. Kostenlos über Beratungshilfe. Sicher & Diskret."
  type="website"
>
  <main class="min-h-screen bg-[#FDFDFD]">
    
    <!-- Ultra Premium Hero Section -->
    <section class="relative pt-32 pb-40 px-6 overflow-hidden bg-[#0a1628]">
      
      <!-- Sophisticated Background -->
      <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20 mix-blend-soft-light pointer-events-none"></div>
      <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-blue-900/20 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>
      <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-indigo-900/10 rounded-full blur-[100px] translate-y-1/2 -translate-x-1/4 pointer-events-none"></div>

      <div class="max-w-6xl mx-auto relative z-10 grid md:grid-cols-2 gap-16 items-center">
        
        <!-- Text Content -->
        <div class="text-left">
           <div class="inline-flex items-center gap-3 mb-8">
              <div class="h-[1px] w-12 bg-[#c5a67c]"></div>
              <span class="text-[#c5a67c] text-xs font-bold uppercase tracking-[0.2em] font-sans">Rechtssicherheit</span>
           </div>

           <h1 class="text-5xl md:text-7xl font-serif font-medium text-white mb-8 leading-[1.1] tracking-tight">
             Sie haben keinen Anspruch <br/>
             <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-slate-400">auf Ihr Geld?</span>
           </h1>
           
           <p class="text-lg md:text-xl text-slate-400 mb-12 max-w-lg leading-relaxed font-light">
             Behördliche Entscheidungen sind oft fehlerhaft. Wir vermitteln Ihren Bescheid an unabhängige Fachanwälte zur kostenlosen Prüfung.
           </p>
           
           <div class="flex flex-col sm:flex-row gap-8 items-start">
              
              <!-- Expertise Item -->
              <div class="flex items-start gap-4 text-white/80 group">
                  <div class="w-12 h-12 rounded-full border border-white/10 flex items-center justify-center bg-white/5 backdrop-blur-sm shrink-0 group-hover:bg-white/10 transition-colors">
                    <span class="text-xl">⚖️</span>
                  </div>
                  <div class="flex flex-col pt-1">
                    <span class="text-xs uppercase tracking-wider text-slate-500 font-bold mb-1">Expertise</span>
                    <span class="font-serif text-lg leading-tight">Fachanwälte</span>
                  </div>
              </div>

              <!-- Divider -->
              <div class="w-[1px] h-16 bg-white/10 hidden sm:block self-stretch"></div>

              <!-- Costs Item -->
              <div class="flex items-start gap-4 text-white/80 group">
                  <div class="w-12 h-12 rounded-full border border-white/10 flex items-center justify-center bg-white/5 backdrop-blur-sm shrink-0 group-hover:bg-white/10 transition-colors">
                    <!-- Shield Icon -->
                    <span class="text-xl">🛡️</span>
                  </div>
                  <div class="flex flex-col pt-1">
                    <span class="text-xs uppercase tracking-wider text-slate-500 font-bold mb-1">Kosten</span>
                    <span class="font-serif text-lg leading-tight mb-1">Staatliche Übernahme</span>
                    <span class="text-[10px] text-slate-400 max-w-[180px] leading-relaxed font-light">
                      Die Staatskasse trägt die Anwaltskosten bei Anspruch auf Beratungshilfe.
                    </span>
                  </div>
              </div>
           </div>
        </div>

        <!-- Quiz Card / Interactive Element -->
        <div class="relative">
             <!-- Gold Accent Line -->
             <div class="absolute -top-6 -left-6 w-24 h-24 border-t border-l border-[#c5a67c]/30 rounded-tl-3xl pointer-events-none"></div>
             
             <!-- The Component -->
             <NoticeCheckQuiz client:load />

             <!-- Gold Accent Line Bottom -->
             <div class="absolute -bottom-6 -right-6 w-24 h-24 border-b border-r border-[#c5a67c]/30 rounded-br-3xl pointer-events-none"></div>
        </div>

      </div>
    </section>



    <!-- Transparenz & Funktionsweise Section -->
    <section class="py-24 px-6 bg-[#f7f8fa]">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-16">
            <span class="text-[#c5a67c] text-xs font-bold uppercase tracking-[0.2em] mb-4 block">Transparenz-Offensive</span>
            <h2 class="text-3xl md:text-5xl font-serif font-medium text-[#0a1628] mb-6">Wie das Modell funktioniert.</h2>
            <p class="text-slate-600 max-w-2xl mx-auto font-light">
                Wir setzen auf maximale Transparenz. Hier erklären wir, warum die Prüfung für Sie kostenlos ist und wer Ihren Fall bearbeitet.
            </p>
        </div>

        <div class="grid gap-12">
            <!-- Schritt 1: Das Modell -->
            <div class="bg-white p-8 md:p-12 rounded-xl shadow-lg border border-slate-100 relative overflow-hidden">
                 <div class="absolute top-0 right-0 w-32 h-32 bg-[#c5a67c]/5 rounded-bl-full -mr-16 -mt-16"></div>
                 <div class="relative z-10">
                     <h3 class="text-2xl font-serif text-[#0a1628] mb-4 flex items-center gap-3">
                        <span class="w-8 h-8 rounded-full bg-[#0a1628] text-white flex items-center justify-center text-sm font-bold">?</span>
                        Warum ist das kostenlos?
                     </h3>
                     <p class="text-slate-600 leading-relaxed font-light mb-6">
                        Der Gesetzgeber möchte, dass jeder Bürger zu seinem Recht kommt, unabhängig vom Geldbeutel. Deshalb gibt es die <strong>staatliche Beratungshilfe</strong>. 
                     </p>
                     <ul class="space-y-3 mb-6">
                         <li class="flex items-start gap-3 text-slate-600 text-sm">
                            <span class="text-[#c5a67c] mt-1">✓</span>
                            <span><strong>Kostenübernahme:</strong> Der Staat trägt die Anwaltskosten für Beratung und Widerspruch bei Bedürftigkeit (Beratungshilfe).</span>
                         </li>
                         <li class="flex items-start gap-3 text-slate-600 text-sm">
                            <span class="text-[#c5a67c] mt-1">✓</span>
                            <span><strong>Keine Eigenbeteiligung:</strong> Die gesetzliche Gebühr von 15 € übernehmen unsere Partneranwälte für Sie.</span>
                         </li>
                         <li class="flex items-start gap-3 text-slate-600 text-sm">
                            <span class="text-[#c5a67c] mt-1">✓</span>
                            <span><strong>Kein Risiko:</strong> Sollte keine Beratungshilfe bewilligt werden, entstehen Ihnen trotzdem keine Kosten durch die Plattform.</span>
                         </li>
                     </ul>
                 </div>
            </div>

            <!-- Schritt 2: Wer prüft? -->
             <div class="flex flex-col md:flex-row gap-8">
                <div class="bg-white p-8 rounded-xl shadow border border-slate-100 flex-1">
                     <h3 class="text-lg font-serif text-[#0a1628] mb-4 font-bold">Ihr Partner: Unabhängige Anwälte</h3>
                     <p class="text-slate-600 text-sm leading-relaxed mb-4">
                        Sozialer Navigator ist eine technische Plattform. Wir vermitteln Ihre Anfrage sicher & verschlüsselt an spezialisierte Kanzleien.
                     </p>
                     <p class="text-slate-600 text-sm leading-relaxed">
                        Die rechtliche Prüfung erfolgt ausschließlich durch zugelassene Rechtsanwälte, die dem anwaltlichen Berufsrecht und der Schweigepflicht unterliegen.
                     </p>
                </div>
                 <div class="bg-white p-8 rounded-xl shadow border border-slate-100 flex-1">
                     <h3 class="text-lg font-serif text-[#0a1628] mb-4 font-bold">Sicherheit & Datenschutz</h3>
                     <p class="text-slate-600 text-sm leading-relaxed mb-4">
                        Ihre Daten sind sensibel. Wir nutzen SSL-Verschlüsselung und Serverstandorte in Deutschland.
                     </p>
                      <div class="flex gap-4 mt-6">
                         <!-- Mock Trust Badges representing Security -->
                         <div class="h-8 w-24 bg-slate-100 rounded flex items-center justify-center text-[10px] text-slate-400 font-bold uppercase tracking-wider">SSL Secure</div>
                         <div class="h-8 w-24 bg-slate-100 rounded flex items-center justify-center text-[10px] text-slate-400 font-bold uppercase tracking-wider">Datenschutz</div>
                      </div>
                </div>
            </div>

        </div>
      </div>
    </section>



    <!-- Content Section: The "Why" (Keep but refined) -->
    <section class="py-24 px-6 bg-[#fdfdfd] border-t border-slate-100">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-16">
            <h2 class="text-3xl font-serif text-[#0a1628] mb-4">Häufige Fehler in Bescheiden</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-12">
          <!-- Card 1 -->
          <div class="group">
            <h3 class="text-xl font-serif text-[#0a1628] mb-3 border-b border-[#c5a67c]/30 pb-2 inline-block">Unterkunft & Heizung</h3>
            <p class="text-slate-600 leading-relaxed font-light text-sm">
                Oft werden Nachzahlungen oder Heizkostenabrechnungen pauschal abgelehnt. Die Angemessenheitsgrenzen sind dabei häufig angreifbar.
            </p>
          </div>
           <!-- Card 2 -->
          <div class="group">
            <h3 class="text-xl font-serif text-[#0a1628] mb-3 border-b border-[#c5a67c]/30 pb-2 inline-block">Einkommen</h3>
            <p class="text-slate-600 leading-relaxed font-light text-sm">
                Die Anrechnung von Erwerbseinkommen ist fehleranfällig. Freibeträge für Erwerbstätigkeit oder Ehrenamt werden oft vergessen.
            </p>
          </div>
           <!-- Card 3 -->
          <div class="group">
            <h3 class="text-xl font-serif text-[#0a1628] mb-3 border-b border-[#c5a67c]/30 pb-2 inline-block">Aufhebungen</h3>
            <p class="text-slate-600 leading-relaxed font-light text-sm">
                Rückforderungen oder Aufhebungsbescheide müssen strengen formalen Kriterien genügen. Hier lohnt sich fast immer eine Prüfung.
            </p>
          </div>
        </div>
      </div>
    </section>



    <!-- Legal Disclaimer Footer -->
    <section class="bg-[#050b14] py-12 px-6 border-t border-white/5">
        <div class="max-w-5xl mx-auto text-xs text-slate-500 font-light leading-relaxed text-center">
            <p class="mb-4">
                <strong>Rechtlicher Hinweis (RDG):</strong> Sozialer Navigator ist keine Rechtsanwaltskanzlei und bietet selbst keine Rechtsberatung an. 
                Wir vermitteln lediglich den Kontakt zu unabhängigen Kooperationsanwälten. Das Mandatsverhältnis kommt ausschließlich zwischen Ihnen und dem jeweiligen Anwalt zustande.
            </p>
            <p>
                <strong>Kostenhinweis:</strong> Die Tätigkeit der Anwälte ist für Sie in der Regel kostenlos, da diese über die staatliche Beratungshilfe abgerechnet wird. 
                Voraussetzung ist Bedürftigkeit (z.B. Bürgergeld-Bezug). Die gesetzliche Selbstbeteiligung von 15 € wird von unseren Partnern oft nicht erhoben.
            </p>
        </div>
    </section>

    <LeadModal />

  </main>
</Layout>

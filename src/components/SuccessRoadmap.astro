---
import { Search, ShieldCheck, PenTool, Sprout } from 'lucide-react';

const steps = [
  {
    icon: Search,
    title: "Klarheit schaffen",
    desc: "Nutze unseren Rechner, um deinen genauen Anspruch zu ermitteln. Ohne Anmeldung, 100% anonym.",
    color: "bg-blue-100 text-blue-600"
  },
  {
    icon: ShieldCheck,
    title: "Sicherheit gewinnen",
    desc: "Mit unserer Checkliste und Experten-Tipps vermeidest du Fehler im Antrag, die Monate kosten könnten.",
    color: "bg-emerald-100 text-emerald-600"
  },
  {
    icon: PenTool,
    title: "Recht durchsetzen",
    desc: "Wir (oder unsere Partner) helfen dir, den Antrag korrekt zu stellen und Widerspruch einzulegen.",
    color: "bg-amber-100 text-amber-600"
  },
  {
    icon: Sprout,
    title: "Finanzielle Freiheit",
    desc: "Erhalte das Geld, das dir zusteht. Durchschnittlich 240€ Wohngeld oder volles Bürgergeld jeden Monat.",
    color: "bg-violet-100 text-violet-600"
  }
];
---

<section class="max-w-7xl mx-auto px-6 py-24 border-t border-slate-100">
    <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl md:text-5xl font-bold text-slate-900 mb-6 tracking-tight">
            Vom Anspruch zur <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-violet-600">Auszahlung.</span>
        </h2>
        <p class="text-lg text-slate-500 font-medium">
            Wir begleiten dich nicht nur beim Rechnen, sondern bis das Geld auf deinem Konto ist.
        </p>
    </div>

    <div class="relative">
        <!-- Connecting Line (Desktop) -->
        <div class="hidden md:block absolute top-12 left-0 w-full h-1 bg-slate-100 -z-10"></div>
        
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
            {steps.map((step, index) => (
                <div class="group relative bg-white p-6 rounded-2xl border border-slate-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                    
                    <!-- Step Number Badge -->
                    <div class="absolute -top-4 -right-4 w-8 h-8 rounded-full bg-slate-900 text-white flex items-center justify-center font-bold text-sm shadow-lg transform group-hover:scale-110 transition-transform">
                        {index + 1}
                    </div>

                    <div class={`w-16 h-16 rounded-2xl ${step.color} flex items-center justify-center mb-6 mx-auto md:mx-0 transform group-hover:rotate-6 transition-transform duration-300`}>
                        <step.icon class="w-8 h-8" />
                    </div>
                    
                    <h3 class="text-xl font-bold text-slate-900 mb-3 text-center md:text-left">{step.title}</h3>
                    <p class="text-slate-500 text-sm leading-relaxed text-center md:text-left">
                        {step.desc}
                    </p>
                </div>
            ))}
        </div>
    </div>

</section>

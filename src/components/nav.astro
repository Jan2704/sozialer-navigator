---
// src/components/Nav.astro
interface Props {
  cityName?: string;
  citySlug?: string;
}
const { cityName, citySlug } = Astro.props;
---

<header class="fixed top-0 z-50 w-full bg-white/85 backdrop-blur-md transition-all duration-300 border-b border-slate-100">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <nav class="flex h-20 items-center justify-between">
      
      <!-- Logo Area -->
      <a href="/" class="flex items-center gap-2.5 group">
        <div class="w-9 h-9 bg-gradient-to-tr from-[#0EA5E9] to-[#0D9488] rounded-xl flex items-center justify-center text-white shadow-md shadow-[#0EA5E9]/10 transition-transform duration-300 group-hover:scale-105">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 12 17 22 12"></polyline></svg>
        </div>
        <span class="font-sans font-black text-xl text-slate-900 tracking-tight group-hover:opacity-85 transition-opacity">
            Amtly
        </span>
      </a>

      <!-- Desktop Nav -->
      <ul class="hidden md:flex items-center gap-8 text-sm font-semibold text-slate-500">
        <li>
          <a href="/" class="hover:text-[#0EA5E9] transition-colors uppercase tracking-wider text-[11px] font-black">Startseite</a>
        </li>
        <li>
          <a href="/ueber-uns/" class="hover:text-[#0EA5E9] transition-colors uppercase tracking-wider text-[11px] font-black">Über Uns</a>
        </li>
      </ul>

      <!-- CTA Buttons -->
      <div class="hidden md:flex items-center gap-3">
          <a href="/#calculator" class="px-5 py-2.5 bg-transparent text-slate-800 hover:text-[#0D9488] hover:border-[#0D9488] transition-all text-xs font-black uppercase tracking-wider rounded-xl border border-slate-200 shadow-sm">
            Anspruch prüfen
          </a>
      </div>

      <!-- Mobile Menu Button -->
      <button class="md:hidden p-2 text-slate-600 hover:bg-slate-50 rounded-xl transition-colors">
         <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>

    </nav>
  </div>
</header>

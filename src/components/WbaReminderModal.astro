---
// src/components/WbaReminderModal.astro
---

<div id="wba-modal-backdrop" class="fixed inset-0 bg-brand-navy/80 backdrop-blur-sm z-[100] hidden items-center justify-center p-4 opacity-0 transition-opacity duration-300">
    <div id="wba-modal-content" class="bg-surface-base w-full max-w-lg shadow-2xl relative border-t-4 border-brand-gold transform scale-95 transition-transform duration-300 rounded-sm">
        
        <!-- Close Button -->
        <button id="close-wba-modal" class="absolute top-4 right-4 text-slate-400 hover:text-brand-navy transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>

        <div class="p-8 md:p-10">
            <div class="text-center mb-8">
                <div class="w-12 h-12 bg-[#f4f1ea] rounded-sm flex items-center justify-center text-brand-gold mx-auto mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                </div>
                <h3 class="font-serif text-3xl text-brand-navy mb-2">WBA-Schutz aktivieren</h3>
                <p class="text-slate-600 font-light text-sm">
                    Lassen Sie sich rechtzeitig an Ihren Weiterbewilligungsantrag erinnern. Wir informieren Sie kostenlos per E-Mail, bevor Ihr Bewilligungszeitraum abläuft.
                </p>
            </div>

            <form id="wba-reminder-form" class="space-y-6">
                <!-- Step 1: Date -->
                <div class="space-y-3">
                    <label class="text-xs font-bold text-brand-navy uppercase tracking-widest block">Wann endet Ihr aktueller Bescheid?</label>
                    <div class="grid grid-cols-2 gap-4">
                        <select id="wba-month" required class="w-full bg-white border border-slate-300 rounded-sm px-4 py-3 text-brand-navy outline-none focus:border-brand-gold focus:ring-1 focus:ring-brand-gold appearance-none">
                            <option value="" disabled selected>Monat</option>
                            <option value="01">01 - Januar</option>
                            <option value="02">02 - Februar</option>
                            <option value="03">03 - März</option>
                            <option value="04">04 - April</option>
                            <option value="05">05 - Mai</option>
                            <option value="06">06 - Juni</option>
                            <option value="07">07 - Juli</option>
                            <option value="08">08 - August</option>
                            <option value="09">09 - September</option>
                            <option value="10">10 - Oktober</option>
                            <option value="11">11 - November</option>
                            <option value="12">12 - Dezember</option>
                        </select>
                        <select id="wba-year" required class="w-full bg-white border border-slate-300 rounded-sm px-4 py-3 text-brand-navy outline-none focus:border-brand-gold focus:ring-1 focus:ring-brand-gold appearance-none">
                            <option value="" disabled selected>Jahr</option>
                            <option value="2024">2024</option>
                            <option value="2025">2025</option>
                            <option value="2026">2026</option>
                            <option value="2027">2027</option>
                        </select>
                    </div>
                    <p class="text-[10px] text-slate-500 font-light mt-1">Sie finden das genaue Enddatum auf der ersten Seite Ihres aktuellen Bewilligungsbescheids.</p>
                </div>

                <!-- Step 2: Contact Info -->
                <div class="space-y-4 pt-4 border-t border-slate-100">
                    <div class="space-y-2">
                        <label for="wba-name" class="text-xs font-bold text-brand-navy uppercase tracking-widest">Ihr Name</label>
                        <input type="text" id="wba-name" required placeholder="Vorname Nachname" class="w-full bg-white border border-slate-300 rounded-sm px-4 py-3 text-brand-navy outline-none focus:border-brand-gold focus:ring-1 focus:ring-brand-gold transition-all" />
                    </div>
                    <div class="space-y-2">
                        <label for="wba-email" class="text-xs font-bold text-brand-navy uppercase tracking-widest">Ihre E-Mail</label>
                        <input type="email" id="wba-email" required placeholder="mail@example.com" class="w-full bg-white border border-slate-300 rounded-sm px-4 py-3 text-brand-navy outline-none focus:border-brand-gold focus:ring-1 focus:ring-brand-gold transition-all" />
                    </div>
                </div>

                <button type="submit" id="wba-submit-btn" class="w-full bg-brand-gold hover:bg-white text-brand-navy font-bold text-xs tracking-widest uppercase py-4 shadow-lg border border-transparent hover:border-brand-gold transition-all duration-300 mt-6 relative overflow-hidden">
                    <span class="relative z-10 flex items-center justify-center gap-2">
                        Kostenlos aktivieren
                    </span>
                    <div class="absolute inset-0 bg-white/20 transform -translate-x-full transition-transform duration-300 group-hover:translate-x-0"></div>
                </button>
                
                <p class="text-[10px] text-center text-slate-500 font-light mt-4">
                    Ihre Daten werden sicher verschlüsselt nach DSGVO übertragen und ausschließlich für den Erinnerungsservice genutzt.
                </p>
            </form>

            <div id="wba-success" class="hidden text-center py-6">
                <div class="w-16 h-16 bg-brand-gold/10 border border-brand-gold/30 rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-brand-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                </div>
                <h4 class="font-serif text-2xl text-brand-navy mb-2">Service aktiviert!</h4>
                <p class="text-slate-600 font-light text-sm mb-6">
                    Wir haben Ihre Daten verzeichnet. Sie erhalten rechtzeitig vor Ablauf Ihres Bescheids eine E-Mail mit dem nötigen WBA-Formular von uns.
                </p>
                <button id="wba-close-success" class="px-6 py-2 bg-surface-muted hover:bg-slate-200 text-brand-navy text-xs font-bold uppercase tracking-widest transition-colors rounded-sm">
                    Schließen
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    const backdrop = document.getElementById('wba-modal-backdrop');
    const content = document.getElementById('wba-modal-content');
    const closeBtn = document.getElementById('close-wba-modal');
    const closeSuccessBtn = document.getElementById('wba-close-success');
    const form = document.getElementById('wba-reminder-form');
    const successMsg = document.getElementById('wba-success');
    const submitBtn = document.getElementById('wba-submit-btn');

    // Open Modal Function (Exposed globally so trigger buttons can call it)
    window.openWbaModal = () => {
        if (!backdrop || !content) return;
        backdrop.classList.remove('hidden');
        backdrop.classList.add('flex');
        // Small delay to allow display flex to apply before opacity transition
        setTimeout(() => {
            backdrop.classList.remove('opacity-0');
            backdrop.classList.add('opacity-100');
            content.classList.remove('scale-95');
            content.classList.add('scale-100');
        }, 10);
        document.body.style.overflow = 'hidden'; // Prevent scrolling
    };

    // Close Modal Function
    const closeModal = () => {
        if (!backdrop || !content) return;
        backdrop.classList.remove('opacity-100');
        backdrop.classList.add('opacity-0');
        content.classList.remove('scale-100');
        content.classList.add('scale-95');
        
        setTimeout(() => {
            backdrop.classList.add('hidden');
            backdrop.classList.remove('flex');
            document.body.style.overflow = '';
            
            // Reset form
            if (form && successMsg) {
                setTimeout(() => {
                    form.reset();
                    form.classList.remove('hidden');
                    successMsg.classList.add('hidden');
                }, 300);
            }
        }, 300);
    };

    // Event Listeners for Closing
    closeBtn?.addEventListener('click', closeModal);
    closeSuccessBtn?.addEventListener('click', closeModal);
    backdrop?.addEventListener('click', (e) => {
        if (e.target === backdrop) closeModal();
    });

    // Handle Form Submission
    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        if (!submitBtn) return;
        
        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = '<span class="flex items-center justify-center gap-2"><svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Verarbeite...</span>';
        submitBtn.disabled = true;

        const name = (document.getElementById('wba-name') as HTMLInputElement).value;
        const email = (document.getElementById('wba-email') as HTMLInputElement).value;
        const month = (document.getElementById('wba-month') as HTMLSelectElement).value;
        const year = (document.getElementById('wba-year') as HTMLSelectElement).value;

        try {
            const response = await fetch('/api/wba-reminder', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name, email, month, year, type: 'WBA_REMINDER' })
            });

            if (response.ok) {
                form.classList.add('hidden');
                successMsg?.classList.remove('hidden');
            } else {
                throw new Error('API Error');
            }
        } catch (error) {
            console.error('Error submitting WBA reminder:', error);
            alert('Es gab einen Fehler bei der Übertragung. Bitte versuchen Sie es später erneut.');
        } finally {
            submitBtn.innerHTML = originalText;
            submitBtn.disabled = false;
        }
    });
</script>

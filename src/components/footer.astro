---
// src/components/Footer.astro

const currentYear = new Date().getFullYear();
---

<footer class="bg-[#0a1628] pt-24 pb-12 relative overflow-hidden border-t-4 border-[#c5a67c]">
  
  <!-- Decorative Background -->
  <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-5 mix-blend-soft-light pointer-events-none"></div>
  <div class="absolute -top-24 -right-24 w-96 h-96 bg-[#c5a67c] rounded-full blur-[100px] opacity-10 pointer-events-none"></div>

  <div class="mx-auto max-w-7xl px-6 relative z-10">
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12 lg:gap-8 mb-20">
      
      <!-- Brand Section -->
      <div class="lg:col-span-2">
        <a href="/" class="group flex items-center gap-3 mb-6">
           <div class="w-10 h-10 bg-white/5 border border-white/10 rounded-sm flex items-center justify-center text-[#c5a67c]">
             <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 12 17 22 12"></polyline></svg>
           </div>
           <div>
              <span class="block text-xl font-serif font-bold text-white tracking-tight">Sozialer Navigator</span>
              <span class="block text-[10px] uppercase tracking-[0.2em] text-[#c5a67c]">Rechtssicherheit</span>
           </div>
        </a>
        <p class="text-sm leading-relaxed text-slate-400 max-w-sm font-light mb-8">
          Wir demokratisieren den Zugang zum Sozialrecht. Durch Technologie machen wir Ansprüche transparent, verständlich und durchsetzbar. Unabhängig und sicher.
        </p>
        
        <!-- Socials / Trust -->
        <div class="flex gap-4">
             <!-- Add social icons or trust seals here if needed -->
        </div>
      </div>

      <!-- Navigation Column 1 -->
      <div class="flex flex-col gap-6">
        <span class="text-xs font-bold uppercase tracking-widest text-white/90">
          Themen
        </span>
        <div class="flex flex-col gap-3">
          <a href="/buergergeld/" class="text-sm text-slate-400 hover:text-[#c5a67c] transition-colors">Bürgergeld</a>
          <a href="/wohngeld/" class="text-sm text-slate-400 hover:text-[#c5a67c] transition-colors">Wohngeld</a>
          <a href="/bescheid-check/" class="text-sm text-slate-400 hover:text-[#c5a67c] transition-colors">Bescheid-Prüfung</a>
          <a href="/ratgeber/" class="text-sm text-slate-400 hover:text-[#c5a67c] transition-colors">Ratgeber & Hilfe</a>
          <a href="/lexikon/" class="text-sm text-slate-400 hover:text-[#c5a67c] transition-colors">Rechts-Lexikon</a>
        </div>
      </div>

      <!-- Navigation Column 2 -->
      <div class="flex flex-col gap-6">
        <span class="text-xs font-bold uppercase tracking-widest text-white/90">
          Städte
        </span>
        <div class="flex flex-col gap-3">
            <a href="/berlin/" class="text-sm text-slate-400 hover:text-[#c5a67c] transition-colors">Berlin</a>
            <a href="/hamburg/" class="text-sm text-slate-400 hover:text-[#c5a67c] transition-colors">Hamburg</a>
            <a href="/muenchen/" class="text-sm text-slate-400 hover:text-[#c5a67c] transition-colors">München</a>
            <a href="/koeln/" class="text-sm text-slate-400 hover:text-[#c5a67c] transition-colors">Köln</a>
            <div class="h-[1px] w-full bg-white/10 my-1"></div>
            <a href="/staedte/" class="text-sm font-medium text-[#c5a67c] hover:text-white transition-colors flex items-center gap-1">Alle Städte anzeigen <i data-lucide="arrow-right" class="w-3 h-3"></i></a>
        </div>
      </div>

      <!-- Navigation Column 3: Legal -->
      <div class="flex flex-col gap-6">
        <span class="text-xs font-bold uppercase tracking-widest text-white/90">
          Kanzlei
        </span>
        <div class="flex flex-col gap-3">
          <a href="/ueber-uns/" class="text-sm text-slate-400 hover:text-[#c5a67c] transition-colors">Über uns</a>
          <a href="/kontakt/" class="text-sm text-slate-400 hover:text-[#c5a67c] transition-colors">Kontakt</a>
          <a href="/impressum/" class="text-sm text-slate-400 hover:text-[#c5a67c] transition-colors">Impressum</a>
          <a href="/datenschutz/" class="text-sm text-slate-400 hover:text-[#c5a67c] transition-colors">Datenschutz</a>
        </div>
      </div>

    </div>

    <!-- Bottom Bar -->
    <div class="pt-8 border-t border-white/10 flex flex-col md:flex-row items-center justify-between gap-6">
      <p class="text-xs text-slate-500 font-medium">
        &copy; {currentYear} Sozialer Navigator. Alle Rechte vorbehalten.
      </p>
    </div>

  </div>
</footer>

---
---
<!-- Benefit Recommendations / "Handlungsempfehlungen" -->
<div class="mt-16 mb-12" id="rec-section">
    <h3 class="font-serif text-2xl font-bold text-[#0a1628] mb-8 flex items-center gap-3">
        <span class="bg-[#0a1628] text-[#c5a67c] w-10 h-10 rounded-xl flex items-center justify-center shadow-lg shadow-slate-200/50">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </span>
        Berechtigte Zusatz-Leistungen
    </h3>
    
    <div class="flex flex-col gap-6">
        
        <!-- Kinderzuschlag (KiZ) - Conditional - NEUTRAL CARD -->
        <div id="rec-card-kiz" class="hidden relative group">
            <div class="relative bg-white border border-slate-200/60 rounded-[2rem] p-8 overflow-hidden flex flex-col md:flex-row gap-8 items-center shadow-sm hover:shadow-md hover:border-[#0a1628]/20 transition-all">
                
                <div class="order-2 md:order-1 flex-1">
                    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-100 border border-slate-200 text-slate-600 text-[10px] font-bold uppercase tracking-widest mb-4">
                        Für Familien
                    </div>
                    <h4 class="font-serif text-2xl font-bold text-[#0a1628] mb-3">Kinderzuschlag (KiZ)</h4>
                    <p class="text-slate-600 mb-6 leading-relaxed font-medium">
                        Zusätzlich zum Kindergeld stehen Ihnen bis zu <strong class="text-[#0a1628]">292€ pro Kind</strong> monatlich zu.
                    </p>
                    <ul class="space-y-3 mb-8">
                        <li class="flex items-center gap-3 text-sm text-slate-500">
                            <div class="w-5 h-5 rounded-full border border-emerald-200 bg-emerald-50 flex items-center justify-center text-emerald-600 text-xs shadow-sm">✓</div>
                            <span>Befreiung von <strong class="text-[#0a1628]">Kita-Gebühren</strong></span>
                        </li>
                        <li class="flex items-center gap-3 text-sm text-slate-500">
                            <div class="w-5 h-5 rounded-full border border-emerald-200 bg-emerald-50 flex items-center justify-center text-emerald-600 text-xs shadow-sm">✓</div>
                            <span>Pauschale für <strong class="text-[#0a1628]">Schulbedarf</strong> (195€)</span>
                        </li>
                    </ul>
                    <a href="#" onclick="window.openLeadModal('kiz'); return false;" class="inline-flex items-center justify-center px-6 py-3 rounded-xl bg-[#0a1628] hover:bg-[#1e293b] text-white font-bold transition-all w-full md:w-auto shadow-md">
                        Anspruch prüfen
                    </a>
                </div>

                <div class="order-1 md:order-2 w-full md:w-1/3 flex justify-center items-center">
                    <div class="w-32 h-32 bg-[#f8fafc] rounded-full flex items-center justify-center border border-slate-100 shadow-inner">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-slate-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 9.5V4a2 2 0 0 1 2-2h11a2 2 0 0 1 2 2v5.5"/><path d="M22 13a6 6 0 0 1-6 6v0a6 6 0 0 1-6-6v-2h12v2Zm-10 6v3a1 1 0 0 0 1 1h2a1 1 0 0 0 1-1v-3"/></svg>
                    </div>
                </div>
            </div>
        </div>

        <!-- AVGS (Coaching) - Always Visible - HERO CARD (Premium) -->
        <div id="rec-card-avgs" class="relative group mt-8">
             <!-- Premium Glow -->
             <div class="absolute -inset-1 bg-gradient-to-r from-slate-200 via-slate-300 to-slate-200 rounded-[2.5rem] blur opacity-50 group-hover:opacity-70 transition duration-1000"></div>
             
             <div class="relative bg-[#0a1628] rounded-[2rem] p-8 md:p-12 border border-[#1e293b] overflow-hidden shadow-2xl">
                
                <!-- Inner Gold/Subtle Background Glow -->
                <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-[#c5a67c] rounded-full blur-[100px] opacity-10 -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>

                <div class="grid md:grid-cols-2 gap-12 items-center relative z-10">
                    <div>
                        <div class="flex flex-wrap gap-2 mb-6">
                            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/10 border border-white/20 text-[#c5a67c] text-[10px] font-bold uppercase tracking-widest shadow-lg">
                                <span class="w-2 h-2 rounded-full bg-[#c5a67c] animate-pulse"></span>
                                Staatliche Förderung
                            </div>
                        </div>
                        
                        <h3 class="font-serif text-4xl md:text-5xl font-bold text-white mb-6 tracking-tight leading-[1.1]">
                            Lassen Sie Ihr Budget <span class="text-[#c5a67c]">nicht verfallen.</span>
                        </h3>
                        
                        <p class="text-slate-300 text-lg mb-8 leading-relaxed max-w-md font-medium">
                            Sie haben einen gesetzlichen <strong class="text-white">Rechtsanspruch (2.500€)</strong> auf dieses Budget. Holen Sie sich, was Ihnen zusteht – bevor es andere tun.
                        </p>
                        
                        <div class="space-y-4 mb-2">
                            <div class="flex items-center gap-4 group/item">
                                <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-[#c5a67c] border border-white/10 group-hover/item:scale-110 transition-transform shadow-sm">✓</div>
                                <div>
                                    <span class="block font-bold text-white">100% Kostenlos</span>
                                    <span class="text-xs text-slate-400">Übernahme durch Agentur für Arbeit / Jobcenter</span>
                                </div>
                            </div>
                            <div class="flex items-center gap-4 group/item">
                                <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-[#c5a67c] border border-white/10 group-hover/item:scale-110 transition-transform shadow-sm">✓</div>
                                <div>
                                    <span class="block font-bold text-white">Freie Wahl</span>
                                    <span class="text-xs text-slate-400">Online oder Vor-Ort Coaching möglich</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="flex flex-col items-center justify-center text-center bg-white/5 backdrop-blur-md rounded-3xl p-8 border border-white/10 shadow-xl relative overflow-hidden group/form">
                        
                        <div class="absolute inset-0 bg-gradient-to-br from-white/5 to-transparent opacity-0 group-hover/form:opacity-100 transition-opacity duration-500"></div>
                        
                        <h4 class="relative z-10 text-white font-bold text-2xl mb-3">Anspruch prüfen</h4>
                        <p class="relative z-10 text-sm text-slate-300 mb-8 max-w-xs mx-auto">
                            Finde in 30 Sekunden heraus, ob dir das Budget zusteht. Unverbindlich & sicher.
                        </p>
                        
                        <a href="#" onclick="window.openLeadModal('avgs'); return false;" class="relative z-10 block w-full mb-4 group/btn">
                            <button class="w-full py-4 px-6 bg-white hover:bg-slate-100 text-[#0a1628] font-bold text-lg rounded-xl transition-all shadow-lg shadow-white/10 flex items-center justify-center gap-3 group-hover/btn:scale-[1.02]">
                                <span>Jetzt Förder-Check starten</span>
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover/btn:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                            </button>
                        </a>
                        
                        <div class="relative z-10 mt-2 flex items-center justify-center gap-4 text-[10px] text-slate-400 uppercase tracking-widest font-bold">
                             <span class="flex items-center gap-1"><svg class="w-3 h-3 text-[#c5a67c]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg> SSL-Sicher</span>
                             <span>•</span>
                             <span>Zertifizierte Partner</span>
                        </div>
                    </div>
                </div>

                <!-- Expanded Content (Integrated from AVGS Page) -->
                <div class="mt-16 pt-10 border-t border-white/10 relative z-10">
                    <p class="text-center text-slate-400 text-[10px] font-bold uppercase tracking-widest mb-8">Wofür du das Budget nutzen kannst</p>
                    
                     <!-- Emotional Benefits -->
                    <div class="grid md:grid-cols-3 gap-6 text-left">
                        <div class="bg-white/5 p-6 rounded-2xl border border-white/10 shadow-sm hover:bg-white/10 hover:border-white/20 transition-all duration-300">
                             <div class="w-12 h-12 bg-white/10 rounded-2xl flex items-center justify-center text-2xl mb-4 text-white shadow-sm border border-white/5">🚀</div>
                             <h3 class="font-bold text-white mb-2">Traumjob finden</h3>
                             <p class="text-sm text-slate-300 leading-relaxed font-medium mb-3">
                                Bewerbungsmappe optimieren, Interview-Training & Zugang zum verdeckten Stellenmarkt.
                             </p>
                        </div>
                         <div class="bg-white/5 p-6 rounded-2xl border border-white/10 shadow-sm hover:bg-white/10 hover:border-white/20 transition-all duration-300">
                             <div class="w-12 h-12 bg-white/10 rounded-2xl flex items-center justify-center text-2xl mb-4 text-white shadow-sm border border-white/5">💼</div>
                             <h3 class="font-bold text-white mb-2">Selbstständigkeit</h3>
                             <p class="text-sm text-slate-300 leading-relaxed font-medium mb-3">
                                Von der Idee zum Businessplan. Bereite alles für den Gründungszuschuss (bis 15.000€) vor.
                             </p>
                        </div>
                         <div class="bg-white/5 p-6 rounded-2xl border border-white/10 shadow-sm hover:bg-white/10 hover:border-white/20 transition-all duration-300">
                             <div class="w-12 h-12 bg-white/10 rounded-2xl flex items-center justify-center text-2xl mb-4 text-white shadow-sm border border-white/5">🧭</div>
                             <h3 class="font-bold text-white mb-2">Neuorientierung</h3>
                             <p class="text-sm text-slate-300 leading-relaxed font-medium mb-3">
                                Stärkenanalyse & Karriereplanung. Finde heraus, welcher Job dich wirklich erfüllt.
                             </p>
                        </div>
                    </div>
                </div>
             </div>
        </div>

        <!-- Bildung & Teilhabe (BuT) - Conditional - NEUTRAL CARD -->
        <div id="rec-card-but" class="hidden relative group bg-white border border-slate-200/60 rounded-2xl p-6 md:p-8 flex flex-col md:flex-row items-center gap-6 shadow-sm">
             <div class="w-16 h-16 rounded-full bg-slate-50 flex items-center justify-center border border-slate-100 shrink-0">
                 <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-slate-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
             </div>
             <div class="flex-1 text-center md:text-left">
                 <h4 class="font-serif text-xl font-bold text-[#0a1628] mb-2">Bildung & Teilhabe Paket (BuT)</h4>
                 <p class="text-slate-500 text-sm font-medium">
                     Ihre Kinder haben zusätzlich Anspruch auf Kostenübernahme für Ausflüge, Sportvereine, Nachhilfe und Schulbedarf (195€/Jahr).
                 </p>
             </div>
             <div class="shrink-0">
                  <div class="bg-slate-50 border border-slate-200/60 text-slate-500 text-[10px] uppercase tracking-widest font-bold px-4 py-2 rounded-lg" title="Wird oft automatisch bewilligt">
                    Wird meist automatisch gewährt
                </div>
             </div>
        </div>
    
    </div>
</div>

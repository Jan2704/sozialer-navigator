---
---
<div class="py-12 bg-slate-50 border-y border-slate-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 items-center justify-items-center text-center opacity-70 hover:opacity-100 transition-opacity duration-500">
            
            <!-- 1. Kostenlos -->
            <div class="flex flex-col items-center gap-3">
                <div class="w-12 h-12 rounded-full bg-white border border-slate-200 flex items-center justify-center text-2xl shadow-sm text-emerald-600">
                    €0
                </div>
                <div>
                    <span class="block text-sm font-bold text-slate-800">100% Kostenlos</span>
                    <span class="block text-xs text-slate-500">Staatlich gefördert</span>
                </div>
            </div>

            <!-- 2. DSGVO -->
            <div class="flex flex-col items-center gap-3">
                <div class="w-12 h-12 rounded-full bg-white border border-slate-200 flex items-center justify-center text-2xl shadow-sm text-blue-600">
                    🛡️
                </div>
                <div>
                    <span class="block text-sm font-bold text-slate-800">Datenschutz</span>
                    <span class="block text-xs text-slate-500">DSGVO-Konform</span>
                </div>
            </div>

            <!-- 3. Made in Germany -->
            <div class="flex flex-col items-center gap-3">
                <div class="w-12 h-12 rounded-full bg-white border border-slate-200 flex items-center justify-center text-2xl shadow-sm">
                    🇩🇪
                </div>
                <div>
                    <span class="block text-sm font-bold text-slate-800">Made in Germany</span>
                    <span class="block text-xs text-slate-500">Für deutsche Behörden</span>
                </div>
            </div>

            <!-- 4. SSL -->
            <div class="flex flex-col items-center gap-3">
                 <div class="w-12 h-12 rounded-full bg-white border border-slate-200 flex items-center justify-center text-2xl shadow-sm text-slate-600">
                    🔒
                </div>
                <div>
                    <span class="block text-sm font-bold text-slate-800">Sichere Übertragung</span>
                    <span class="block text-xs text-slate-500">SSL-Verschlüsselt</span>
                </div>
            </div>

        </div>
    </div>
</div>

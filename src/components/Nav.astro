---
// src/components/Nav.astro
interface Props {
  cityName?: string;
  citySlug?: string;
}
const { cityName, citySlug } = Astro.props;
---

<header class="fixed top-0 z-50 w-full bg-white/95 backdrop-blur-md transition-all duration-300 border-b border-slate-100">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <nav class="flex h-20 items-center justify-between">
      
      <!-- Logo Area -->
      <a href="/" class="flex items-center gap-2 group">
        <div class="w-8 h-8 bg-[#0a1628] rounded-sm flex items-center justify-center text-[#c5a67c]">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 12 17 22 12"></polyline></svg>
        </div>
        <span class="font-serif text-lg font-bold text-[#0a1628] tracking-tight group-hover:opacity-80 transition-opacity">
            Sozialer Navigator
        </span>
      </a>

      <!-- Desktop Nav -->
      <ul class="hidden md:flex items-center gap-10 text-sm font-medium text-slate-600">
        <li>
          <a href="/" class="hover:text-[#0a1628] transition-colors uppercase tracking-wider text-xs">Start</a>
        </li>
        <li>
          <a href="/wohngeld/" class="hover:text-[#0a1628] transition-colors uppercase tracking-wider text-xs">Wohngeld</a>
        </li>
        <li>
          <a href="/buergergeld/" class="hover:text-[#0a1628] transition-colors uppercase tracking-wider text-xs">Bürgergeld</a>
        </li>
        <li>
          <a href="/ratgeber/" class="hover:text-[#0a1628] transition-colors uppercase tracking-wider text-xs">Ratgeber</a>
        </li>
        <li>
          <a href="/ueber-uns/" class="hover:text-[#0a1628] transition-colors uppercase tracking-wider text-xs">Über Uns</a>
        </li>
      </ul>

      <!-- CTA Buttons -->
      <div class="hidden md:flex items-center gap-3">
          <a href="/#calculator" class="px-6 py-2.5 bg-transparent text-[#0a1628] hover:bg-slate-100 transition-colors text-xs font-bold uppercase tracking-widest rounded-sm border border-[#0a1628]/20">
            Anspruch prüfen
          </a>
          <a href="/bescheid-check/" class="px-6 py-2.5 bg-[#0a1628] text-[#c5a67c] hover:bg-[#112340] transition-colors text-xs font-bold uppercase tracking-widest rounded-sm border border-[#c5a67c]/20">
            Bescheid prüfen
          </a>
      </div>

      <!-- Mobile Menu Button (Placeholder for future implementation if needed, simplistic for now) -->
      <button class="md:hidden p-2 text-slate-600">
         <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>

    </nav>
  </div>
</header>

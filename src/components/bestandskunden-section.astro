---
// src/components/bestandskunden-section.astro
---

<div id="bestandskunden" class="w-full bg-white py-32 border-t border-slate-100 scroll-mt-20">
    <div class="max-w-7xl mx-auto px-6">
        
        <!-- Header -->
        <div class="text-center mb-20 max-w-3xl mx-auto">
             <!-- Modern Badge -->
             <div class="inline-flex items-center gap-2 mb-6 px-4 py-2 rounded-full bg-[#0EA5E9]/5 border border-[#0EA5E9]/15 backdrop-blur-sm">
                 <span class="flex h-2 w-2 rounded-full bg-[#0EA5E9] animate-pulse"></span>
                 <span class="text-[#0EA5E9] text-xs font-black tracking-widest uppercase">Bereits im Leistungsbezug?</span>
             </div>
             
             <h2 class="text-4xl md:text-5xl font-sans font-black text-slate-900 mb-6 leading-tight">
                Machen Sie <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#0EA5E9] to-[#0D9488]">mehr</span> aus Ihrem Anspruch.
             </h2>
             <p class="text-slate-600 text-lg font-light leading-relaxed">
                 Auch wenn du bereits Wohngeld oder Bürgergeld beziehst, lassen sich oft weitere Ansprüche geltend machen. Wir unterstützen dich dabei effizient und rechtssicher.
             </p>
        </div>

        <!-- Cards Grid -->
        <div class="grid md:grid-cols-3 gap-8">
             
             <!-- Card 1: Bescheid prüfen -->
             <a href="/bescheid-check/" class="group block relative bg-white p-10 border border-slate-200/80 rounded-3xl hover:shadow-2xl hover:border-[#0EA5E9]/30 hover:-translate-y-1 transition-all duration-300">
                  <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-[#0EA5E9] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                  
                  <div class="w-16 h-16 bg-slate-50 flex items-center justify-center rounded-2xl mb-8 group-hover:bg-[#0EA5E9] group-hover:text-white transition-colors duration-300 border border-slate-100">
                      <i data-lucide="file-search" class="w-8 h-8 text-[#0EA5E9] group-hover:text-white transition-colors"></i>
                  </div>
                  
                  <h3 class="text-2xl font-sans font-black text-slate-900 mb-4">Bescheid prüfen lassen</h3>
                  <p class="text-slate-600 font-light leading-relaxed mb-8">
                      Nahezu jeder zweite Bescheid ist fehlerhaft. Lassen Sie Experten prüfen, ob Ihnen rückwirkend mehr Geld zusteht.
                  </p>
                  
                  <span class="inline-flex items-center gap-2 text-xs font-black uppercase tracking-wider text-slate-900 group-hover:text-[#0EA5E9] transition-colors">
                      zur Prüfung <i data-lucide="arrow-right" class="w-4 h-4"></i>
                  </span>
             </a>

             <!-- Card 2: AVGS -->
             <a href="/avgs/" class="group block relative bg-white p-10 border border-slate-200/80 rounded-3xl hover:shadow-2xl hover:border-[#0D9488]/30 hover:-translate-y-1 transition-all duration-300">
                  <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-[#0D9488] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                  
                  <div class="absolute top-4 right-4 bg-[#0D9488]/10 text-[#0D9488] text-[9px] font-black uppercase tracking-wider px-3 py-1 rounded-full border border-[#0D9488]/20">
                      100% Gefördert
                  </div>

                  <div class="w-16 h-16 bg-slate-50 flex items-center justify-center rounded-2xl mb-8 group-hover:bg-[#0D9488] group-hover:text-white transition-colors duration-300 border border-slate-100">
                      <i data-lucide="graduation-cap" class="w-8 h-8 text-[#0D9488] group-hover:text-white transition-colors"></i>
                  </div>
                  
                  <h3 class="text-2xl font-sans font-black text-slate-900 mb-4">Weiterbildung (AVGS)</h3>
                  <p class="text-slate-600 font-light leading-relaxed mb-8">
                      Sichern Sie sich ein amtlich gefördertes Coaching (Wert bis zu 2.500€) für Ihre berufliche Weiterentwicklung oder Selbstständigkeit.
                  </p>
                  
                  <span class="inline-flex items-center gap-2 text-xs font-black uppercase tracking-wider text-slate-900 group-hover:text-[#0D9488] transition-colors">
                      Gutschein anfragen <i data-lucide="arrow-right" class="w-4 h-4"></i>
                  </span>
             </a>

             <!-- Card 3: Fristen / WBA Fristen-Service -->
             <div class="group relative bg-[#0D9488]/5 border border-[#0D9488]/15 p-10 rounded-3xl hover:shadow-2xl hover:bg-[#0D9488]/10 transition-all duration-300 flex flex-col justify-between overflow-hidden">
                  <!-- Background accent -->
                  <div class="absolute -right-20 -top-20 w-64 h-64 bg-[#0EA5E9]/10 opacity-30 rounded-full blur-3xl group-hover:opacity-50 transition-opacity duration-700"></div>

                  <div class="relative z-10">
                      <div class="w-16 h-16 bg-[#0D9488]/10 rounded-2xl flex items-center justify-center mb-8 border border-[#0D9488]/20">
                          <i data-lucide="bell" class="w-8 h-8 text-[#0D9488]"></i>
                      </div>
                      
                      <h3 class="text-2xl font-sans font-black text-slate-900 mb-4">WBA Fristen-Service</h3>
                      <p class="text-slate-600 font-light leading-relaxed mb-8">
                          Verpassen Sie nie wieder Ihren Weiterbewilligungsantrag. Tragen Sie das Ablaufdatum Ihres Bescheids ein und wir erinnern Sie rechtzeitig.
                      </p>
                  </div>
                  
                  <button onclick="window.openWbaModal?.()" class="relative z-10 w-full py-4.5 bg-[#0EA5E9] text-white hover:bg-[#38bdf8] hover:shadow-lg hover:shadow-[#0EA5E9]/20 transition-all font-black text-xs uppercase tracking-wider rounded-xl flex items-center justify-center gap-2 border border-transparent">
                      Erinnerung einrichten <i data-lucide="clock" class="w-4 h-4"></i>
                  </button>
             </div>

        </div>
        
        <!-- Mehrbedarf Teaser -->
        <div class="mt-16 text-center">
            <span class="text-slate-500 font-light italic text-sm">
                Suchen Sie Informationen zu Mehrbedarfen (Zusatzkosten für Schwangerschaft, Warmwasser, etc.)? 
                <a href="/lexikon/buergergeld" class="text-[#0EA5E9] hover:text-[#0D9488] font-semibold underline decoration-1 underline-offset-4 transition-colors">Details im Lexikon</a>.
            </span>
        </div>

    </div>
</div>

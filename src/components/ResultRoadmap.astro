import AuthoritySearch from './AuthoritySearch.astro';
import PartnerCTA from './PartnerCTA.astro';
---
<!-- Result Roadmap / "Fahrplan" -->
<div id="result-roadmap" class="mt-8 mb-16 relative">
    
    <div class="absolute -left-10 top-0 w-64 h-full bg-blue-50/20 blur-3xl pointer-events-none"></div>

    <h3 class="text-2xl font-bold text-slate-900 mb-10 flex items-center gap-3 relative z-10">
        <span class="bg-gradient-to-br from-blue-500 to-indigo-600 text-white w-10 h-10 rounded-xl flex items-center justify-center text-lg shadow-lg shadow-blue-500/20">🚀</span>
        Ihr Fahrplan zum Antrag
    </h3>
    
    <div class="relative space-y-8 pl-4 md:pl-0">
        
        <!-- Vertical Connector Line (Glowing Gradient) -->
        <div class="absolute left-8 md:left-1/2 top-6 bottom-6 w-0.5 bg-gradient-to-b from-blue-500 via-indigo-400 to-slate-200 -translate-x-1/2 hidden md:block shadow-[0_0_10px_rgba(59,130,246,0.6)]"></div>
        <div class="absolute left-4 top-6 bottom-6 w-0.5 bg-gradient-to-b from-blue-500 to-slate-200 md:hidden"></div>

        <!-- Step 1: Formloser Antrag -->
        <div class="relative flex flex-col md:flex-row items-start md:items-center gap-6 md:gap-0 group">
            <div class="md:w-1/2 md:pr-16 md:text-right order-2 md:order-1">
                <div class="bg-white/80 backdrop-blur-md border border-slate-100 p-6 rounded-2xl shadow-sm hover:shadow-md hover:border-blue-200 transition-all duration-300 relative group-hover:-translate-y-1">
                    <h4 class="font-bold text-slate-900 text-lg mb-2 group-hover:text-blue-600 transition-colors">1. Formlosen Antrag stellen</h4>
                    <p class="text-sm text-slate-600 leading-relaxed font-medium mb-4">
                        Senden Sie <strong class="text-slate-900">sofort</strong> eine formlose E-Mail an Ihre Behörde. Damit sichern Sie Ihren Anspruch rückwirkend für den gesamten Monat!
                    </p>
                    
                    <!-- Search Widget -->
                    <div class="text-left mb-4 relative z-20"> <!-- z-20 for dropdown -->
                        <AuthoritySearch />
                    </div>

                    <div class="mt-3 pt-3 border-t border-slate-100">
                        <p class="text-xs text-slate-500">
                            <span class="font-bold text-blue-600">Das passiert danach:</span>
                            Die Behörde bestätigt den Eingang und sendet Ihnen die offiziellen Antragsformulare sowie eine Liste benötigter Unterlagen per Post zu.
                        </p>
                    </div>
                    <!-- Arrow for Desktop -->
                    <div class="hidden md:block absolute top-1/2 -right-3 w-4 h-4 bg-white border-t border-r border-slate-100 transform rotate-45 -translate-y-1/2 group-hover:border-blue-200 transaction-colors"></div>
                </div>
            </div>
            
            <!-- Icon: Number 1 -->
            <div class="absolute left-4 md:left-1/2 w-10 h-10 rounded-full bg-slate-900 text-white border-4 border-white shadow-lg shadow-blue-900/20 z-10 transform -translate-x-1/2 flex items-center justify-center font-bold text-sm order-1 md:order-2 group-hover:scale-110 transition-transform duration-300">
                1
            </div>
            
            <div class="md:w-1/2 md:pl-16 order-3">
                <div class="hidden md:flex items-center gap-2">
                    <span class="px-3 py-1 bg-emerald-50 text-emerald-600 text-[10px] font-bold uppercase tracking-wider rounded-full border border-emerald-100">
                        Wichtigster Schritt
                    </span>
                </div>
            </div>
        </div>

        <!-- Step 2: Antrag einreichen -->
        <div class="relative flex flex-col md:flex-row items-start md:items-center gap-6 md:gap-0 group">
            <div class="md:w-1/2 md:pr-16 md:text-right order-2 md:order-1">
                 <div class="hidden md:block text-xs font-bold text-slate-400 uppercase tracking-widest group-hover:text-slate-600 transition-colors">Dokumente</div>
            </div>
            
            <!-- Icon: Number 2 -->
            <div class="absolute left-4 md:left-1/2 w-10 h-10 rounded-full bg-white text-slate-600 border-4 border-slate-50 shadow-md z-10 transform -translate-x-1/2 flex items-center justify-center font-bold text-sm order-1 md:order-2 group-hover:bg-blue-50 group-hover:text-blue-600 group-hover:border-blue-100 transition-all duration-300">
                2
            </div>
            
            <div class="md:w-1/2 md:pl-16 order-3">
                <div class="bg-white/80 backdrop-blur-md border border-slate-100 p-6 rounded-2xl shadow-sm hover:shadow-md hover:border-blue-200 transition-all duration-300 relative group-hover:-translate-y-1">
                    <h4 class="font-bold text-slate-900 text-lg mb-2 group-hover:text-blue-600 transition-colors">2. Unterlagen vorbereiten</h4>
                    <p class="text-sm text-slate-600 leading-relaxed font-medium mb-4">
                        Reichen Sie das offizielle Formular und Nachweise (Mietvertrag, Einkommen) nach.
                    </p>
                    <!-- Arrow for Desktop -->
                    <div class="hidden md:block absolute top-1/2 -left-3 w-4 h-4 bg-white border-b border-l border-slate-100 transform rotate-45 -translate-y-1/2 group-hover:border-blue-200 transaction-colors"></div>
                </div>
            </div>
        </div>

        <!-- Step 3: Bearbeitung / Experte -->
        <div class="relative flex flex-col md:flex-row items-start md:items-center gap-6 md:gap-0 group">
            <div class="md:w-1/2 md:pr-16 md:text-right order-2 md:order-1">
                <div class="bg-white/80 backdrop-blur-md border border-slate-100 p-6 rounded-2xl shadow-sm hover:shadow-md transition-all duration-300 relative group-hover:-translate-y-1">
                    <h4 class="font-bold text-slate-900 text-lg mb-2">3. Bearbeitung & Geduld</h4>
                    <p class="text-sm text-slate-600 leading-relaxed font-medium">
                Die Bearbeitung dauert oft <span class="text-amber-600 font-bold">mehrere Monate</span>. Fehlende Unterlagen verzögern die Auszahlung weiter!
            </p>
            
            <div class="mt-4 pt-4 border-t border-slate-100">
                <a href="/avgs" class="flex items-center gap-3 group/avgs hover:bg-blue-50/50 p-2 -mx-2 rounded-lg transition-colors mb-3">
                    <div class="w-10 h-10 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold text-lg shrink-0 group-hover/avgs:scale-110 transition-transform shadow-sm">🚀</div>
                    <div class="text-xs text-slate-500 text-left leading-snug">
                        <span class="block font-bold text-blue-600 mb-0.5">Wartezeit sinnvoll nutzen?</span>
                        Holen Sie sich Ihr <span class="underline decoration-blue-300 font-medium text-slate-700">2.500€ Coaching-Budget</span>.
                    </div>
                </a>
                
                <!-- Partner CTA for Legal -->
                <PartnerCTA 
                    type="legal" 
                    title="Ablehnung erhalten?" 
                    description="Lassen Sie Ihren Bescheid kostenlos vom Anwalt prüfen." 
                    buttonText="Gratis Prüfung"
                />
            </div>
                     <!-- Arrow for Desktop -->
                    <div class="hidden md:block absolute top-1/2 -right-3 w-4 h-4 bg-white border-t border-r border-slate-100 transform rotate-45 -translate-y-1/2"></div>
                </div>
            </div>
            
            <!-- Icon: Number 3 -->
            <div class="absolute left-4 md:left-1/2 w-10 h-10 rounded-full bg-white text-slate-400 border-4 border-slate-50 shadow-sm z-10 transform -translate-x-1/2 flex items-center justify-center font-bold text-sm order-1 md:order-2">
                3
            </div>
            
            <div class="md:w-1/2 md:pl-16 order-3 pt-6 md:pt-0">
                 <!-- Expert Help CTA "Bubble" - Enhanced Light -->
                 <div class="bg-white border border-blue-100 rounded-2xl p-6 shadow-xl relative overflow-hidden group/card hover:border-blue-300 hover:shadow-blue-200 transition-all duration-300 transform hover:-translate-y-1">
                    <!-- Glow Effect -->
                    <div class="absolute -top-10 -right-10 w-32 h-32 bg-blue-50 rounded-full blur-3xl group-hover/card:bg-blue-100 transition-colors opacity-60"></div>
                    
                    <h5 class="text-slate-900 font-bold text-base mb-2 flex items-center gap-2 relative z-10">
                        🛡️ Ihr Sicherheitspaket
                    </h5>
                    
                    <p class="text-xs text-slate-600 mb-4 leading-relaxed relative z-10 font-medium">
                        Vermeiden Sie Formfehler. Nutzen Sie unsere <strong>rechtssicheren Vorlagen</strong> (Anwaltlich geprüft).
                    </p>

                    <!-- List of benefits -->
                    <ul class="text-[10px] text-slate-500 mb-5 space-y-1.5 relative z-10">
                        <li class="flex items-center gap-2">
                            <svg class="w-3.5 h-3.5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Rechtssichere Formulierung für den Antrag
                        </li>
                        <li class="flex items-center gap-2">
                            <svg class="w-3.5 h-3.5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Checkliste aller benötigten Unterlagen
                        </li>
                    </ul>

                    <button onclick="window.openLeadModal('pdf-checklist');" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs py-3 rounded-xl shadow-md shadow-blue-500/20 transition-all flex items-center justify-center gap-2 group-hover/card:shadow-lg relative z-10">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="12" y1="18" x2="12" y2="12"></line><line x1="9" y1="15" x2="15" y2="15"></line></svg>
                        <span>Kostenloses PDF-Paket anfordern</span>
                    </button>
                    <p class="text-[10px] text-slate-400 mt-2 text-center relative z-10">
                        Senden wir Ihnen sofort per E-Mail zu.
                    </p>
                 </div>
            </div>
        </div>
    </div>


</div>

---

import BenefitRecommendations from './benefit-recommendations.astro';
import LeadModal from './lead-modal.astro';
import AuthorityApp from './authority-app.jsx';
import PartnerCTA from './partner-cta.astro';
---

<section id="view-results" class="view-section max-w-6xl mx-auto hidden opacity-0 transition-opacity duration-500 pt-32 pb-24 px-6 relative z-20">
    
    <!-- Header with Print/Reset -->
    <div class="mb-12 flex flex-col md:flex-row md:items-center justify-between gap-6">
         <div class="flex items-center gap-4">
             <button id="btn-back-home" class="md:hidden p-3 -ml-2 text-slate-400 hover:text-slate-900 transition-colors rounded-xl hover:bg-slate-100">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
             </button>
             <div>
                 <h2 class="font-serif text-4xl md:text-5xl font-bold text-[#0a1628] tracking-tight">Ergebnis für <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#0a1628] to-slate-500" id="res-city-header">--</span></h2>
                 <p class="text-slate-500 font-medium mt-1">Unverbindliche Ersteinschätzung</p>
             </div>
         </div>
         <div class="flex gap-3">
            <button onclick="window.print()" class="hidden md:flex items-center gap-2 px-5 py-3 bg-white border border-slate-200 rounded-xl text-slate-600 font-bold hover:bg-slate-50 transition-all shadow-sm hover:shadow-md text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect width="12" height="8" x="6" y="14"/></svg>
                Drucken
            </button>
             <button onclick="location.reload()" class="items-center gap-2 px-5 py-3 bg-blue-50 border border-blue-100 rounded-xl text-blue-600 font-bold hover:bg-blue-100 transition-all shadow-sm hover:shadow-md text-sm flex">
                 <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-blue-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 12"/></svg>
                 <span class="hidden md:inline">Neu berechnen</span>
             </button>
         </div>
    </div>

    <!-- Bento Grid (Zyntra Style) -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- Hero Card (Amount) - Span 2 -->
        <div class="col-span-1 md:col-span-2 bg-white border border-slate-200/60 p-8 md:p-10 rounded-[2.5rem] relative overflow-hidden flex flex-col justify-between min-h-[320px] shadow-xl shadow-slate-200/40 group hover:shadow-slate-200/60 transition-shadow duration-500">
            <!-- Background Decor -->
            <div class="absolute top-0 right-0 w-80 h-80 bg-slate-50 rounded-full blur-3xl -mr-20 -mt-20 pointer-events-none opacity-80"></div>
            
            <div class="relative z-10">
                <div class="inline-flex items-center gap-2 bg-[#0a1628] text-white px-4 py-1.5 rounded-full text-[10px] font-bold uppercase tracking-widest mb-8 shadow-md">
                    <span class="w-2 h-2 rounded-full bg-[#c5a67c] animate-pulse"></span>
                    Anspruch berechnet
                </div>
                <h3 class="text-slate-400 font-bold text-sm mb-2 uppercase tracking-widest">Ihr voraussichtlicher Zuschuss</h3>
                
                <!-- DEFAULT CONTENT -->
                <div id="res-hero-default">
                    <div class="flex items-baseline gap-2 mb-2">
                         <span id="res-amount-hero" class="font-serif text-7xl md:text-8xl font-bold text-[#0a1628] tracking-tighter drop-shadow-sm">0€</span>
                         <span class="text-2xl text-slate-400 font-bold">/ Monat</span>
                    </div>
                </div>

                <!-- HIDDEN PARTNER CTA -->
                <div id="res-partner-cta" class="hidden my-4">
                     <div class="flex flex-col gap-4">
                        <span class="text-4xl md:text-5xl font-black text-slate-300 line-through decoration-red-400 decoration-4 mb-2">0€</span>
                        <PartnerCTA 
                            type="legal" 
                            title="Experten-Prüfung anfordern"
                            description="Unser Rechner hat keinen Anspruch gefunden. Da Rechenfehler bei komplexen Fällen (Freibeträge) häufig sind, empfehlen wir eine kostenlose Prüfung durch einen Anwalt."
                            buttonText="Kostenlos Fall prüfen lassen"
                        />
                     </div>
                </div>

                <p id="res-type-hero" class="text-[#c5a67c] font-bold text-xl tracking-wide flex items-center gap-2">
                    Wohngeld
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                </p>
            </div>
            <div class="mt-8 pt-6 border-t border-slate-100 relative z-10">
                <p class="text-xs text-slate-400 font-medium flex gap-2 items-start">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0 mt-0.5 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                    <span>*Dies ist eine unverbindliche Berechnung auf Basis Ihrer Eingaben. <span id="res-context-text"></span></span>
                </p>
            </div>
        </div>

        <!-- Analysis Card (Chart) - Span 1 -->
        <div class="col-span-1 bg-white border border-slate-200/60 p-8 rounded-[2.5rem] flex flex-col items-center justify-center relative shadow-xl shadow-slate-200/30">
             <h4 class="absolute top-8 left-8 text-xs font-bold text-slate-400 uppercase tracking-widest">Entlastung</h4>
             <div class="relative w-48 h-48 mt-4">
                 <canvas id="analysisChart"></canvas>
                 <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none">
                     <span class="text-3xl font-serif font-bold text-[#0a1628]" id="analysis-percent">0%</span>
                     <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mt-1">Gedeckt</span>
                 </div>
             </div>
             <p class="text-center text-xs text-slate-400 mt-6 font-medium bg-slate-50 px-3 py-1.5 rounded-lg border border-slate-100">Anteil an Ihrer Kaltmiete</p>
        </div>

        <!-- NEW: Reasoning & Breakdown Card - Span 3 -->
        <div class="col-span-1 md:col-span-3 bg-[#f8fafc] border border-slate-200/60 p-6 md:p-8 rounded-[2rem] relative overflow-hidden shadow-sm animate-in fade-in slide-in-from-bottom-4 duration-700">
             <div class="flex items-start gap-4">
                 <div class="p-3 bg-white text-[#c5a67c] border border-slate-100 shadow-sm rounded-xl shrink-0">
                     <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                 </div>
                 <div class="w-full">
                     <h4 class="font-serif font-bold text-[#0a1628] text-xl mb-1 mt-0.5">Warum dieses Ergebnis?</h4>
                     <p id="res-reason-text" class="text-slate-600 leading-relaxed mb-6">
                        Die Berechnung wird geladen...
                     </p>
                     
                     <!-- Calculation Details (Toggleable or Always Visible) -->
                     <div class="bg-white border border-slate-100 rounded-xl p-5 shadow-sm">
                         <h5 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-4 border-b border-slate-100 pb-2">Berechnungsgrundlage</h5>
                         
                         <!-- Dynamic Table Container -->
                         <div id="res-calculation-details" class="space-y-2 text-sm">
                            <!-- Filled by JS -->
                         </div>
                     </div>
                 </div>
             </div>
        </div>

        <!-- Authority Finder & Application - Span 3 (Full Width) -->
         <div class="col-span-1 md:col-span-3 mt-8">
             <AuthorityApp client:load />
         </div>
         

         
         
         <!-- RECOMMENDATIONS - Span 3 -->
         <div class="col-span-1 md:col-span-3">
             <BenefitRecommendations />
         </div>
         

    </div>
    
    <!-- Modals -->
    <LeadModal />
</section>

<script>
    console.log("ResultsSection: Script initializing...");

    // 1. DEFINE SHOWVIEW GLOBALLY FIRST (Critical for Navigation)
    window.showView = (viewId) => {
        console.log("showView called for:", viewId);
        
        const homeView = document.getElementById('view-home');
        const resultsView = document.getElementById('view-results');

        if (viewId === 'results') {
            if (homeView) homeView.style.display = 'none'; // HARD HIDE
            if (resultsView) {
                resultsView.classList.remove('hidden');
                resultsView.style.display = 'block';
                resultsView.style.opacity = '1'; // Ensure visible
                
                // Scroll to top
                window.scrollTo(0, 0);
            }
        } else if (viewId === 'home') {
            if (resultsView) resultsView.style.display = 'none';
            if (homeView) {
                homeView.style.display = 'block';
                window.scrollTo(0, 0); 
            }
        }
    };

    document.getElementById('btn-back-home')?.addEventListener('click', () => {
        window.showView('home');
    });

    // 2. MAIN EVENT LISTENER
    window.addEventListener('benefit-calculation-completed', async (event) => {
        console.log("ResultsSection: Event Received", event.detail);
        
        // Save for React components (AuthorityApp)
        window.lastCalculationResult = event.detail;

        const { detail: result } = event;
        const { input, amount, type, details } = result;

        // Switch View Immediately
        window.showView('results');

        // Hero Values
        const amountEl = document.getElementById('res-amount-hero');
        const typeEl = document.getElementById('res-type-hero');
        const cityHeader = document.getElementById('res-city-header');
        const contextText = document.getElementById('res-context-text');

        if(amountEl && typeEl) {
             // Animate Counter
             let start = 0;
             const end = Math.round(amount);
             const duration = 1000;
             const startTime = performance.now();

             const animate = (currentTime) => {
                 const elapsed = currentTime - startTime;
                 const progress = Math.min(elapsed / duration, 1);
                 
                 // EaseOutQuart
                 const ease = 1 - Math.pow(1 - progress, 4);
                 
                 const currentVal = Math.floor(start + (end - start) * ease);
                 amountEl.textContent = `${currentVal}€`;

                 if (progress < 1) {
                     requestAnimationFrame(animate);
                 } else {
                     amountEl.textContent = `${end}€`;
                 }
             };
             requestAnimationFrame(animate);

             typeEl.textContent = type.toLowerCase().includes('wohngeld') ? 'Wohngeld-Zuschuss' : 
                                  type === 'Grundsicherung im Alter' ? 'Grundsicherung (Alter)' :
                                  type === 'BAföG-Prüfung' ? 'BAföG-Check empfohlen' : 
                                  'Bürgergeld-Regelsatz';
             
             // Special Styling for BAföG
             if (type === 'BAföG-Prüfung') {
                 amountEl.textContent = "BAföG?";
                 amountEl.classList.remove('text-7xl', 'md:text-8xl');
                 amountEl.classList.add('text-5xl', 'md:text-6xl');
                 
                 // Inject BAföG specific help
                 amountEl.parentElement.innerHTML = `
                    <div class="flex flex-col items-start gap-4">
                        <span class="text-4xl md:text-5xl font-black text-brand-blue">BAföG vorrangig!</span>
                        <div class="bg-blue-50 border border-blue-100 rounded-xl p-4 text-sm text-blue-800">
                            <strong>Hinweis für Studierende/Azubis:</strong><br>
                            Sie haben meist keinen Anspruch auf Bürgergeld, da BAföG/BAB vorrangig ist. Wohngeld ist nur im Ausnahmefall möglich (z.B. "dem Grunde nach" kein BAföG).
                        </div>
                        <button onclick="window.openLeadModal('pdf-checklist')" class="group relative inline-flex items-center justify-center gap-3 bg-blue-600 hover:bg-blue-700 text-white font-bold px-6 py-3 rounded-xl shadow-lg shadow-blue-600/20 transition-all hover:scale-[1.02]">
                            <span>Checkliste: BAföG & Wohngeld</span>
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                        </button>
                    </div>
                 `;
             }

             const cityName = (typeof input.city === 'object' && input.city !== null) ? input.city.stadt : input.city;
             
             if(cityHeader && cityName) cityHeader.textContent = cityName;
             
             if(contextText) {
                 contextText.textContent = `Basierend auf Ihren Angaben für ${cityName || 'Ihren Wohnort'}.`;
             }
        }

        // RECOMMENDATIONS LOGIC (Critical for User Value)
        try {
            const recSection = document.getElementById('rec-section');
            
            // ---------------------------------------------------------
            // ZERO RESULT HANDLER (Lead Magnet)
            // ---------------------------------------------------------
            const partnerCtaContainer = document.getElementById('res-partner-cta');
            const defaultHeroContent = document.getElementById('res-hero-default');

            if (amount === 0) {
                 // 1. Update Hero Card to "No Claim" State
                 if(amountEl && typeEl) {
                     amountEl.textContent = "0€";
                     typeEl.innerHTML = `
                        <span class="text-slate-400">Kein Anspruch erkannt</span>
                     `;
                     
                     // Change "Anspruch berechnet" badge to Warning/Info
                     const badge = document.querySelector('.bg-\\[\\#0a1628\\]');
                     if(badge) {
                         badge.className = "inline-flex items-center gap-2 bg-slate-100 text-slate-700 border border-slate-200 px-4 py-1.5 rounded-full text-[10px] font-bold uppercase tracking-widest mb-8 shadow-sm";
                         badge.innerHTML = `<span class="w-2 h-2 rounded-full bg-slate-400 animate-pulse"></span> Ergebnis unsicher?`;
                     }

                     // Show Partner CTA, Hide Default Amount
                     if (partnerCtaContainer) partnerCtaContainer.classList.remove('hidden');
                     if (defaultHeroContent) defaultHeroContent.classList.add('hidden');
                 }
            } else {
                 // Reset/Ensure Normal State (in case of re-calc)
                 if (partnerCtaContainer) partnerCtaContainer.classList.add('hidden');
                 if (defaultHeroContent) defaultHeroContent.classList.remove('hidden');
                 
                 // Reset Badge
                 const badge = document.querySelector('.bg-slate-100.text-slate-700');
                 if(badge) {
                     badge.className = "inline-flex items-center gap-2 bg-[#0a1628] text-white px-4 py-1.5 rounded-full text-[10px] font-bold uppercase tracking-widest mb-8 shadow-md";
                     badge.innerHTML = `<span class="w-2 h-2 rounded-full bg-[#c5a67c] animate-pulse"></span> Anspruch berechnet`;
                 }
            }

            if(recSection) {
                 // Check Children and Income for KiZ
                 const hasKids = input.kids && input.kids > 0;
                 const income = input.income || 0;
                 
                 const kizCard = document.getElementById('rec-card-kiz');
                 if(kizCard) {
                     if(hasKids && income > 800) { // Rough heuristic
                         kizCard.classList.remove('hidden');
                     } else {
                         kizCard.classList.add('hidden');
                     }
                 }

                 const butCard = document.getElementById('rec-card-but');
                 if(butCard) {
                     if(hasKids) {
                         butCard.classList.remove('hidden');
                         butCard.classList.add('flex');
                     } else {
                         butCard.classList.add('hidden');
                         butCard.classList.remove('flex');
                     }
                 }
                 
                 // Ensure Section is Visible
                 recSection.classList.remove('hidden');
            }
        } catch (recErr) {
            console.warn("Recommendations Error:", recErr);
        }

        // Confetti (Immediate Reward)
        if(window.confetti) {
            window.confetti({
                particleCount: 100,
                spread: 70,
                origin: { y: 0.6 },
                colors: ['#4F46E5', '#10B981', '#F59E0B']
            });
        }

        // --- REASONING & BREAKDOWN ---
        try {
            const reasonEl = document.getElementById('res-reason-text');
            const detailsEl = document.getElementById('res-calculation-details');
            
            if (reasonEl && result.comparison && result.comparison.reason) {
                reasonEl.textContent = result.comparison.reason;
            } else if (reasonEl) {
                reasonEl.textContent = "Die Berechnung wurde erfolgreich durchgeführt.";
            }

            if (detailsEl && details) {
                let rows = '';

                // Format Currency Helper
                const f = (val) => (val || 0).toLocaleString('de-DE', { style: 'currency', currency: 'EUR' });

                if (type.includes('Bürgergeld') || type.includes('Grundsicherung')) {
                    // Bürgergeld Breakdown
                    rows += `
                        <div class="flex justify-between py-1 border-b border-slate-50">
                            <span class="text-slate-500">Regelbedarf</span>
                            <span class="font-medium text-slate-900">${f(details.standardRate)}</span>
                        </div>
                        <div class="flex justify-between py-1 border-b border-slate-50">
                            <span class="text-slate-500">Miete & Heizung (anerkannt)</span>
                            <span class="font-medium text-slate-900">${f((details.eligibleRent || 0) + (details.eligibleHeating || 0))}</span>
                        </div>
                        <div class="flex justify-between py-1 border-b border-slate-50">
                            <span class="text-slate-500">Mehrbedarfe</span>
                            <span class="font-medium text-slate-900">${f(details.mehrbedarf)}</span>
                        </div>
                        <div class="flex justify-between py-1 border-b border-slate-200 bg-red-50/50 px-2 -mx-2 rounded">
                            <span class="text-red-600 font-medium">Anrechenbares Einkommen</span>
                            <span class="font-bold text-red-600">-${f(details.countableIncome)}</span>
                        </div>
                         <div class="flex justify-between py-2 mt-1 border-t border-slate-200">
                            <span class="font-bold text-slate-900">Ihr Anspruch</span>
                            <span class="font-bold text-emerald-600">${f(amount)}</span>
                        </div>
                    `;
                } else if (type === 'Wohngeld') {
                    // Wohngeld Breakdown
                    // Note: API returns slightly different structure for Wohngeld details
                    const m = details.eligibleRent || 0;
                    const y = details.formulaComponents ? details.formulaComponents.Y : 0; // Monthly Income for WoGG
                    
                    rows += `
                        <div class="flex justify-between py-1 border-b border-slate-50">
                            <span class="text-slate-500">Berücksichtigte Miete</span>
                            <span class="font-medium text-slate-900">${f(m)}</span>
                        </div>
                         <div class="flex justify-between py-1 border-b border-slate-50">
                            <span class="text-slate-500">Gesamteinkommen (WoGG)</span>
                            <span class="font-medium text-slate-900">${f(y)}</span>
                        </div>
                         <div class="flex justify-between py-2 mt-1 border-t border-slate-200">
                            <span class="font-bold text-slate-900">Wohngeld-Zuschuss</span>
                            <span class="font-bold text-emerald-600">${f(amount)}</span>
                        </div>
                    `;
                } else {
                     rows += `<div class="text-slate-400 italic py-2">Details zur Berechnung nicht verfügbar.</div>`;
                }

                detailsEl.innerHTML = rows;
            }

        } catch (reasonErr) {
            console.error("Reasoning UI Error:", reasonErr);
        }

        // --- PRIORITY 3: HEAVY ASSETS (Chart) ---
        // Moved to end to prevent blocking
        try {
            const chartCanvas = document.getElementById('analysisChart');
            if(chartCanvas) {
                // Destroy old instance if exists
                if(window.resultChart) {
                    window.resultChart.destroy();
                }

                // Calculate Percentages
                const rent = input.rent || 1;
                const cover = Math.min((amount / rent) * 100, 100).toFixed(0);
                
                const percentEl = document.getElementById('analysis-percent');
                if(percentEl) percentEl.textContent = `${cover}%`;

                // @ts-ignore
                window.resultChart = new Chart(chartCanvas, {
                    type: 'doughnut',
                    data: {
                        labels: ['Gedeckt', 'Eigenanteil'],
                        datasets: [{
                            data: [amount, Math.max(0, rent - amount)],
                            backgroundColor: ['#0a1628', '#e2e8f0'], // Premium Navy, Slate-200
                            borderWidth: 0,
                            hoverOffset: 4
                        }]
                    },
                    options: {
                        cutout: '85%',
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: { enabled: false }
                        },
                        animation: {
                            animateScale: true,
                            animateRotate: true,
                            duration: 1500,
                            easing: 'easeOutQuart'
                        }
                    }
                });
            }
        } catch (chartErr) {
             console.warn("Chart Error:", chartErr);
        }
    });
</script>
